---
/**
 * SiteHeader (v2) — real logo + scroll-reveal nav.
 *
 * Ben (2026-06-16):
 *   • Real logo in the header, appropriately sized (logo height ~44px,
 *     30–50% larger than typical per GL-003 §4 — "doesn't scale small well").
 *   • Menu hidden while at the very top (over the hero); appears only after
 *     the user scrolls past the hero entirely.
 *   • Menu items (Revision 6): "Event Formats" (→ #audiences; shortened from
 *     "Audience and Event Formats" so the 3 items fit one line on mobile),
 *     "The Ninja Way" (→ #the-ninjas), "Packages" (→ #packages).
 *   • Revision 6 (Ben): a "Let's Talk" CTA button to the RIGHT of "Packages"
 *     (the site's primary action — gradient pop per GL-003 §2/§8). href="#" +
 *     data-pending="cta-destination" like the other CTAs (Mack's layer wires it).
 *   • Revision 6 (Ben) MOBILE: the "Let's Talk" CTA sits beside the logo in the
 *     header top row (the nav links wrap to their own line beneath).
 *
 * Header obeys the same container/max-width as the rest of the site (Ben, May 27).
 * Logo: real transparent PNG (master mark), src/assets/logo/av-ninjas-logo.png.
 * The scroll-reveal is progressive enhancement: with no JS the header is simply
 * visible (the safe end state).
 */
import { Image } from "astro:assets";
import logo from "../assets/logo/av-ninjas-logo.png";

const navItems = [
  // Revision 6 (Ben): shortened "Audience and Event Formats" → "Event Formats" so
  // the three nav items fit on one line on mobile (short label used everywhere).
  { label: "Event Formats", href: "#audiences" },
  { label: "The Ninja Way", href: "#the-ninjas" },
  { label: "Packages", href: "#packages" },
] as const;
---

<header class="site-header" id="site-header" data-reveal="shown">
  <div class="container site-header__inner">
    <a href={import.meta.env.BASE_URL} class="site-header__logo" aria-label="AV Ninjas home">
      <Image
        src={logo}
        alt="AV Ninjas"
        height={44}
        densities={[1, 2]}
        loading="eager"
        class="site-header__logo-img"
      />
    </a>
    <nav class="site-header__nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <!-- Revision 6 (Ben): primary "Let's Talk" CTA, to the right of "Packages".
         Gradient pop — the same primary action as the hero/mid/final CTAs (GL-003
         §2 use #1: recurrence of the one promoted action is sanctioned, not spread).
         Placeholder destination like the others. On mobile this sits beside the
         logo (the nav wraps below — see the media query). -->
    <a
      href="#"
      class="btn btn--gradient site-header__cta"
      data-pending="cta-destination"
    >Let's Talk</a>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-canvas) 92%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--color-cream);
    /* Scroll-reveal: slide up + fade out while over the hero; drop in once past it. */
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition:
      transform var(--motion-dark-fade) var(--ease-out),
      opacity var(--motion-dark-fade) var(--ease-out);
  }
  .site-header[data-reveal="shown"] {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding-block: var(--space-md);
  }
  /* Logo left, nav takes the slack, CTA pinned right (Revision 6). */
  .site-header__nav { margin-left: auto; }
  .site-header__cta { margin-left: var(--space-lg); }
  .site-header__logo {
    display: inline-flex;
    border-radius: var(--radius-sm);
  }
  .site-header__logo-img {
    height: 44px; /* logo height target 40–48px per GL-003 §4 */
    width: auto;
  }
  .site-header__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg) var(--space-xl);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-body);
  }
  .site-header__nav a {
    color: var(--color-ink);
    text-decoration: none;
    padding-block: var(--space-xs);
    transition: color var(--motion-micro) var(--ease-out);
  }
  .site-header__nav a:hover {
    color: var(--color-accent);
  }

  /* Header CTA (Revision 6): the gradient primary, sized DOWN for the nav bar —
     the base .btn (--text-body-lg + --space-lg/2xl padding) is body-CTA scale and
     too large for a header. Keep the gradient pop + pill, trim the type + padding. */
  .site-header__cta.btn {
    font-size: var(--text-small);
    padding: var(--space-sm) var(--space-lg);
    flex: none;
    white-space: nowrap;
  }
  /* Revision 7 (Ben): the NAV "Let's Talk" gradient outline is too thick at the
     global --border-pop (5px / 4px mobile). Thin it for the small header pill ONLY —
     the hero "Let's Talk!", the No-Funny-Business CTA, and the final CTA are left at
     the global --border-pop (untouched). Scoped override of the border WIDTH only;
     the --gradient-pop rim + background-clip mask are unchanged, so it stays the same
     gradient pop, just a finer rim suited to the smaller nav button. */
  .site-header__cta.btn--gradient {
    border-width: 2px;
  }

  /* Mobile: logo + "Let's Talk" CTA share the top row (CTA beside the logo, Ben
     Revision 6 7b); the three short nav links wrap to their own full-width line
     beneath. The CTA is pinned right of the logo by pushing the nav to 100% width
     on the second row. */
  @media (max-width: 600px) {
    .site-header__inner {
      flex-wrap: wrap;
      gap: var(--space-md) var(--space-md);
    }
    /* CTA beside the logo: it stays on row 1, pushed to the right edge. */
    .site-header__cta { margin-left: auto; }
    /* Nav drops to its own full-width second row, after the logo + CTA. */
    .site-header__nav {
      order: 3;
      flex-basis: 100%;
      margin-left: 0;
    }
    .site-header__nav ul {
      gap: var(--space-md) var(--space-lg);
      font-size: var(--text-small);
      justify-content: flex-start;
      flex-wrap: nowrap; /* the 3 short labels fit one line (Ben Revision 6 7a) */
    }
  }
  /* No-JS / reduced-motion safety: the header is simply present (end state). */
  @media (prefers-reduced-motion: reduce) {
    .site-header {
      transition: none;
    }
  }
</style>

<script>
  /* Reveal the header only after the user has scrolled PAST the hero entirely
     (Ben, 2026-06-16). Hidden at the very top; appears once #hero leaves the
     viewport. Progressive enhancement — without JS the header stays shown. */
  const header = document.getElementById("site-header");
  const hero = document.getElementById("hero");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (header && hero && !reduceMotion && "IntersectionObserver" in window) {
    const obs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          // Show the header once the hero is no longer intersecting (scrolled past).
          header.dataset.reveal = entry.isIntersecting ? "hidden" : "shown";
        }
      },
      { threshold: 0 },
    );
    obs.observe(hero);
  } else if (header) {
    // No-JS path can't run this, but reduced-motion / no-IO users get it shown.
    header.dataset.reveal = "shown";
  }
</script>

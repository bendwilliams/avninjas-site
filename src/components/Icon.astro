---
/**
 * Icon — the AV Ninjas custom icon set, authored as inline SVG (vector, never
 * AI-rendered) per Pixel's §D icon-description track and the GL-003 §5 icon
 * language:
 *   • 24px grid, 1.75px stroke (v2), rounded joins/caps, geometric, single-weight
 *   • monochrome `currentColor` by default (inherits the section's ink/light)
 *   • COLOR appears ONLY where the system designates it:
 *       - Ignition package icon → accent teal (caller sets `color`)
 *       - status colors → comparison chart ONLY (lives in ComparisonTable.astro)
 *
 * Every glyph is drawn at a 24×24 viewBox so the whole set shares one optical
 * weight. Equipment is IMPLIED, never literal (a soundwave, not a console) —
 * imagery doctrine §3.3 carried into the icon language.
 *
 * Source specs: direction-and-briefs.md §D (D.1–D.6).
 */

// Slugs grouped by Pixel's §D set: D.1 package cards, D.3 A-La-Carte,
// D.4 Attention verbs, D.5 Mission Control, D.6 Capabilities.
export type IconName = "pkg-essentials" | "pkg-conference" | "pkg-ignition" | "alacarte-lobby" | "alacarte-breakout" | "alacarte-content" | "attention-inspire" | "attention-motivate" | "attention-inform" | "attention-strategize" | "mc-comms" | "mc-control" | "mc-visibility" | "cap-audio" | "cap-video" | "cap-graphics" | "cap-lighting" | "solid-sleep" | "solid-backforth" | "solid-whackamole" | "solid-lifting";

interface Props {
  /** Which glyph to render. */
  name: IconName;
  /** Pixel box size in px (square). Default 32. */
  size?: number;
  /** Accessible label. Omit (or "") for decorative — renders aria-hidden. */
  label?: string;
  /** Stroke override (e.g. accent teal for Ignition). Default currentColor. */
  color?: string;
  /** Extra class hook. */
  class?: string | undefined;
}

const { name, size = 32, label = "", color, class: className } = Astro.props;

// Each entry is the inner markup of a 24×24 viewBox, single-weight 1.5px line.
const glyphs: Record<IconName, string> = {
  // ---- Solid-AV trio (GL-003 §5a — Ben 2026-06-16: these were MISSING) ----
  // Sleep like a Baby: a crescent moon (calm rest), not a literal baby.
  "solid-sleep": `
    <path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z"/>
    <path d="M17 3.5l.7 1.6 1.6.7-1.6.7-.7 1.6-.7-1.6-1.6-.7 1.6-.7Z"/>`,
  // Skip the Back and Forth: two opposed arrows resolving to a single check.
  "solid-backforth": `
    <path d="M3 8h11l-2.5-2.5"/>
    <path d="M3 8l2.5 2.5"/>
    <path d="M21 14H10l2.5-2.5"/>
    <path d="M21 14l-2.5 2.5"/>
    <path d="M16.5 19.5l1.8 1.8 3.2-3.6"/>`,
  // Skip the Back and Forth — ALT (Ben "try a whack-a-mole"): a mallet poised over
  // a mole popping from its hole. Ties to the "whack-a-mole pricing" line in the copy.
  // Old "solid-backforth" kept above in case Ben prefers it.
  "solid-whackamole": `
    <rect x="13.5" y="2.8" width="7.7" height="3.6" rx="1"/>
    <path d="M17.3 6.4V11"/>
    <ellipse cx="8.5" cy="19" rx="6" ry="2"/>
    <path d="M4.6 19a4 4.6 0 0 1 7.8 0"/>
    <circle cx="6.1" cy="15.2" r="1"/>
    <circle cx="10.9" cy="15.2" r="1"/>
    <circle cx="7.1" cy="17.4" r="0.55"/>
    <circle cx="9.9" cy="17.4" r="0.55"/>`,
  // We do the Heavy Lifting: a clean dumbbell.
  "solid-lifting": `
    <path d="M6.5 12h11"/>
    <path d="M4 9v6"/><path d="M6.5 8v8"/>
    <path d="M20 9v6"/><path d="M17.5 8v8"/>`,

  // ---- D.1 Package cards ----
  // Essentials: a presenter screen + a small podium/soundwave — solid basics.
  "pkg-essentials": `
    <rect x="3" y="4" width="18" height="11" rx="1.5"/>
    <path d="M9 19h6"/>
    <path d="M12 15v4"/>
    <path d="M7 9.5h2"/><path d="M11 8h2"/><path d="M15 9.5h2"/>`,
  // Conference: stage with two flanking screens — the meat-and-potatoes room.
  "pkg-conference": `
    <rect x="2.5" y="5" width="5" height="8" rx="1"/>
    <rect x="16.5" y="5" width="5" height="8" rx="1"/>
    <path d="M9 11.5h6"/>
    <path d="M8 16h8l1 3H7l1-3Z"/>
    <path d="M12 11.5V16"/>`,
  // Ignition: an upward spark/ignition burst — the premium tier (teal, set by caller).
  "pkg-ignition": `
    <path d="M13 2 5 13h5l-1 9 8-12h-5l1-8Z"/>`,

  // ---- D.3 A-La-Carte ----
  // Lobby: a display-on-stand with a directional arrow — dynamic signage.
  "alacarte-lobby": `
    <rect x="3" y="3" width="18" height="12" rx="1.5"/>
    <path d="M12 15v4"/><path d="M8 21h8"/>
    <path d="M8 9h6"/><path d="M11 6.5 13.5 9 11 11.5"/>`,
  // Breakout: a small screen + a few seats — smaller parallel sessions.
  "alacarte-breakout": `
    <rect x="6" y="3" width="12" height="8" rx="1.5"/>
    <path d="M12 11v2"/>
    <circle cx="5" cy="17" r="1.6"/><circle cx="12" cy="17" r="1.6"/><circle cx="19" cy="17" r="1.6"/>
    <path d="M3 21c0-1.4 .9-2.2 2-2.2s2 .8 2 2.2"/>
    <path d="M10 21c0-1.4 .9-2.2 2-2.2s2 .8 2 2.2"/>
    <path d="M17 21c0-1.4 .9-2.2 2-2.2s2 .8 2 2.2"/>`,
  // Content capture: a video camera / play frame — capture & sizzle reels.
  "alacarte-content": `
    <rect x="3" y="6" width="13" height="12" rx="1.5"/>
    <path d="M16 10l5-3v10l-5-3"/>
    <path d="M10 9.5v5l4-2.5-4-2.5Z"/>`,

  // ---- D.4 Attention verbs ----
  // Inspire: a lightbulb spark.
  "attention-inspire": `
    <path d="M9 18h6"/><path d="M10 21h4"/>
    <path d="M12 3a6 6 0 0 1 4 10.5c-.8.7-1 1.3-1 2.5H9c0-1.2-.2-1.8-1-2.5A6 6 0 0 1 12 3Z"/>`,
  // Motivate (REPLACED — old rising-arrow "screamed AI", Ben 2026-06-16). A
  // concrete, literal flag-on-summit: a peak with a planted pennant flag. No
  // abstract spark/burst/glow. GL-003 §5a anti-AI guard.
  "attention-motivate": `
    <path d="M3 21h18"/>
    <path d="M5 21 11 6l4 8 2-3 2 10"/>
    <path d="M11 6V3"/>
    <path d="M11 3h5l-1.4 2L16 7h-5"/>`,
  // Inform: an open book / info.
  "attention-inform": `
    <path d="M12 6c-2-1.5-5-1.5-7-1v12c2-.5 5-.5 7 1 2-1.5 5-1.5 7-1V5c-2-.5-5-.5-7 1Z"/>
    <path d="M12 6v12"/>`,
  // Strategize: a target.
  "attention-strategize": `
    <circle cx="12" cy="12" r="8.5"/>
    <circle cx="12" cy="12" r="4.5"/>
    <circle cx="12" cy="12" r="1"/>`,

  // ---- D.5 Mission Control 1-2-3 ----
  // Comms: a chat bubble + headset arc — private crew channel.
  "mc-comms": `
    <path d="M4 5h16v10H9l-4 3v-3H4V5Z"/>
    <path d="M9 9.5h6"/><path d="M9 12h4"/>`,
  // Control: sliders / push-update.
  "mc-control": `
    <path d="M4 7h10"/><path d="M18 7h2"/><circle cx="16" cy="7" r="2"/>
    <path d="M4 17h2"/><path d="M10 17h10"/><circle cx="8" cy="17" r="2"/>`,
  // Visibility: a monitor with a multi-feed grid.
  "mc-visibility": `
    <rect x="3" y="4" width="18" height="12" rx="1.5"/>
    <path d="M3 10h18"/><path d="M12 4v12"/>
    <path d="M9 20h6"/><path d="M12 16v4"/>`,

  // ---- D.6 Capabilities columns (equipment IMPLIED) ----
  // Audio: a waveform.
  "cap-audio": `
    <path d="M3 12h2"/><path d="M7 8v8"/><path d="M11 4v16"/><path d="M15 7v10"/><path d="M19 10v4"/><path d="M21 12h0"/>`,
  // Video / streaming: a play frame with signal.
  "cap-video": `
    <rect x="3" y="5" width="14" height="14" rx="1.5"/>
    <path d="M9 9.5v5l4-2.5-4-2.5Z"/>
    <path d="M19 8a4 4 0 0 1 0 8"/><path d="M21 6a7 7 0 0 1 0 12"/>`,
  // Graphics / presentation: a slide frame.
  "cap-graphics": `
    <rect x="3" y="4" width="18" height="12" rx="1.5"/>
    <path d="M6 8h7"/><path d="M6 11.5h5"/>
    <path d="M9 16v3"/><path d="M7 21l2-2 2 2"/>`,
  // Lighting / scenic: a spotlight beam.
  "cap-lighting": `
    <path d="M9 3h6l1 4H8l1-4Z"/>
    <path d="M8 7 4 21"/><path d="M16 7l4 14"/>
    <path d="M10 13h4"/>`,
};

const inner = glyphs[name];
const a11y: Record<string, string> = label
  ? { role: "img", "aria-label": label }
  : { "aria-hidden": "true" };
---

<svg
  class:list={["icon", className]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke={color ?? "currentColor"}
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  {...a11y}
  set:html={inner}
/>

<style>
  .icon {
    display: inline-block;
    vertical-align: middle;
    flex: none;
  }
</style>

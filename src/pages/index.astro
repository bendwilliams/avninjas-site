              src={missionControlImg}
              alt={missionControlAlt}
              widths={[480, 768, 1376]}
              sizes="(min-width: 920px) 42vw, 100vw"
              loading="lazy"
            />
          </div>
          <div class="split__copy">
            <p>Every package comes with your own battle station, customized for how you like to work!</p>
            <p>Because live events are dynamic in nature and every second matters.</p>
            <!-- Revision 8 (Ben): emphasize "why should the ninjas get to play with all
                 the cool toys?" in BLUE. Mission Control is a LIGHT (canvas) ground, so
                 this takes the light-voice accent --color-accent (#1D4ED8, AA 6.4:1) —
                 NOT --color-accent-bright (#60A5FA, which is the DARK-ground voice and
                 fails on light, §9). The span wraps existing characters only; "(and
                 because..." and the trailing ")" stay outside, so both fidelity strings
                 ("(and because..." and the full line) match unchanged. -->
            <p>(and because... <span class="emph-accent">why should the ninjas get to play with all the cool toys?)</span></p>
          </div>
        </div>
        <ol class="mission-groups">
          {missionGroups.map((group, i) => (
            <li class="mission-step">
              <div class="mission-step__head">
                <span class="mission-step__num" aria-hidden="true">{i + 1}</span>
                <Icon name={group.icon} size={28} />
                <h3 class="mc-head">{group.title}</h3>
              </div>
              <ul>
                {group.items.map((item) => <li>{item}</li>)}
              </ul>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ============ 13. A LA CARTE (cream — GRID, head CENTERED, COMPRESSED) ============ -->
    <section class="section section--cream alacarte band-tight" id="a-la-carte" aria-label="A La Carte">
      <div class="container">
        <h2 class="sec-head">A La Carte Services</h2>
        <div class="trio-grid alacarte-grid">
          {alaCarte.map((col) => (
            <div>
              <div class="alacarte-icon"><Icon name={col.icon} size={40} /></div>
              <h3 class="alacarte-title">{col.title}</h3>
              {col.lead && <p class="small alacarte-lead">{col.lead}</p>}
              <ul class="alacarte-list small">
                {col.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 14. FULL BREAKDOWN OF CAPABILITIES (canvas — GRID, head CENTERED) ============ -->
    <!-- §15 FIX: head CENTERED (was LEFT). Centered grid of capability columns;
         lines left-aligned INSIDE each centered column (sweep §A.2). -->
    <section class="section band-tight" id="capabilities" aria-label="Capabilities">
      <div class="container">
        <div class="sec-head">
          <h2>Full Breakdown of our Capabilities</h2>
          <p class="lead">
            Our packages are just the start! Let us know what you need and we'll either make
            it happen or point you in the right direction.
          </p>
        </div>
        <div class="cap-grid">
          {capabilities.map((col) => (
            <div class="cap-col">
              <h3 class="cap-title"><Icon name={col.icon} size={24} />{col.title}</h3>
              <ul class="cap-list small">
                {col.items.map((item) =>
                  typeof item === "string" ? (
                    <li>{item}</li>
                  ) : (
                    <li>
                      {item.label}
                      <ul class="cap-sublist">
                        {item.sub.map((s) => <li>{s}</li>)}
                      </ul>
                    </li>
                  ),
                )}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <hr class="band-break-rule" aria-hidden="true" />

    <!-- ============================================================
         CLOSE — Numbers → Manufacturers → Final CTA. Canvas, closing on the
         --color-ink final CTA (the last earned dark). (§B.1)
         ============================================================ -->

    <!-- ============ 15. THE NUMBERS (cream — CENTERED, count-up) ============ -->
    <!-- §13: scroll-triggered count-up / reveal on the 1.5 - 3.5x figure.
         CENTERED archetype (shout/stat moment), 900 measure. -->
    <section class="section section--cream center" id="the-numbers" aria-label="The Numbers">
      <div class="container">
        <div class="sec-head sec-head--wide">
          <h2>The numbers don't lie</h2>
          <p>
            <strong>"Just add it to the final invoice"</strong> is a phrase used far too often in the
            live event industry. <span class="emph-red-deep">We think that's transactional and gross.</span>
          </p>
          <p>
            <strong>We guarantee no surprises on our end. If we can't produce a paper trail for a
            revision, you don't pay!</strong>
          </p>
          <!-- v3 in-body Resources link (Hook copy-pack-v2 §4): ONE contextual link
               in the cost/pricing section → /resources/, value/transparency anchor.
               Intent-bearing, matches the A2 article frame. -->
          <p>
            And if you want to see exactly <a href="/resources/">where your AV budget actually goes</a>,
            we broke it down for you.
          </p>
        </div>
        <div class="stat" id="numbers-stat">
          <p class="stat__figure tabular" data-countup="1.5 - 3.5x">1.5 - 3.5x</p>
          <p class="stat__label">Typical Savings</p>
        </div>
      </div>
    </section>

    <!-- ============ 16. NAIL-DOWN CTA (canvas — CENTERED) ============ -->
    <section class="section center band-tight" id="nailed-down" aria-label="Nail-down CTA">
      <div class="container">
        <div class="sec-head sec-head--wide">
          <h2>Let's get this nailed down!</h2>
          <p class="lead">The ninjas are standing by to transform your vision into reality.</p>
        </div>
        <!-- Primary Let's-Talk-class action → gradient. Destination = Free Planning
             Call (general-site universal door per Ben's 2026-06-26 ruling; audit URL is
             lander-only). -->
        <a href="https://calendly.com/ben-avninjas/free-planning-call" class="btn btn--gradient" target="_blank" rel="noopener noreferrer">Let's Talk</a>
      </div>
    </section>

    <!-- ============ 17. TRUSTED MANUFACTURERS (cream — MARQUEE, label CENTERED) ============ -->
    <!-- §14: the strip now SCROLLS as a marquee (same Marquee component/behavior
         as the event-types ticker). Cohesive monochrome styled-wordmark
         placeholders, rendered + scrolling. [PENDING BEN: real vector logos.] -->
    <section class="section section--cream center band-tight" id="manufacturers" aria-label="Trusted Manufacturers">
      <div class="container">
        <h2 class="sec-head">Trusted Manufacturers</h2>
      </div>
      <Manufacturers />
    </section>


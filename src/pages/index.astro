---
/**
 * AV Ninjas homepage — round-3 / v4 build.
 *
 * COPY LAW (Ben, May 27): every word and punctuation mark below is verbatim
 * from Deliverables/2026-06-12-av-ninjas-website-build-inputs/06-canonical-copy/
 * homepage-copy.md. Doubled periods, "?!?", "Eek!!", "Heww boy..", the hero
 * grammar ("our whole business built around making it easy!") are STRATEGIC,
 * not typos. Do not "fix" anything here without Ben's ruling.
 *
 * v4 = Iris's holistic sweep (Deliverables/.../11-iris-design-sweep.md):
 *   • Poppins superfamily (tokens.css + global.css).
 *   • ALIGNMENT SYSTEM (§A): section heads always CENTERED; content is a
 *     grid-locked SPLIT (.split — text+image share one top/bottom edge) or a
 *     centered GRID. Same section type → same archetype. Fixes Capabilities
 *     (→ centered) and The Ninjas (→ grid-locked split).
 *   • BAND GROUPING (§B): 4 bands, shared background tone per band, one earned
 *     dark moment per band, tighter intra-band spacing.
 *   • FULL-BLEED moments (§C): 3 only — Audiences opener, Band3→4 curtain,
 *     Final CTA. Static (not motion).
 *
 * MOTION BUDGET (GL-003 §7 — the list is closed):
 *   1. Hero highlight-draw on load (the ONLY animated highlight, §6)
 *   2. Phone-buzz on scroll-into-view ("Sound Dramatic?") — screen wakes, one
 *      message slides in, subtle buzz; registered to the photographed phone.
 *   3. Light→dark fade section transitions ([data-dark-fade])
 *   Plus the count-up reveal on the Numbers stat (scroll-triggered number, a
 *   micro-reveal — not a new "moment", degrades to the static end state).
 */
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Marquee from "../components/Marquee.astro";
import ComparisonTable from "../components/ComparisonTable.astro";
import Manufacturers from "../components/Manufacturers.astro";
import Icon from "../components/Icon.astro";
import type { IconName } from "../components/Icon.astro";

// Hero-tier real imagery. v4 per-slot winners (Mack INDEX QA, sweep §"PLACE"):
//   hero          ← img-hero-trio/v3-variant-1 (clear left margin + cleanest logo)
//   mission-ctrl  ← img-mission-control/v3-variant-2 (best eyes-on-screens; CLIENT
//                    at her black-desk battle station, professional attire, delighted)
//   the-gear      ← img-the-gear/v3-variant-2 (cleanest loading read: behind the
//                    case, pushing up the ramp INTO the van, interior full of cases)
import heroTrioImg from "../assets/images/img-hero-trio.png";
import missionControlImg from "../assets/images/img-mission-control.png";

import theNinjasImg from "../assets/images/img-the-ninjas.jpg";
import curtainNinjasImg from "../assets/images/img-curtain-ninjas.jpg";
import theGearImg from "../assets/images/img-the-gear.jpg";
import finalCtaImg from "../assets/images/img-final-cta.jpg";
import audInPersonImg from "../assets/images/img-audiences-in-person.jpg";
import audHybridImg from "../assets/images/img-audiences-hybrid.jpg";
import audVirtualImg from "../assets/images/img-audiences-virtual.jpg";
// Round-4: the REAL back-logo composite (Mack §13) for the Attention section;
// the transparent alien (Mack §15) dropped inline after "alien abduction".
import attentionImg from "../assets/images/img-attention.png";
import alienImg from "../assets/images/img-alien.png";

// Alt text drawn from the Stage-B imagery briefs (direction-and-briefs.md §B).
const heroTrioAlt =
  "Three AV Ninjas technicians in black logo polos stand side-stage at a corporate ballroom event, a full crowd and warm stage light behind them.";
const missionControlAlt =
  "The event organizer at her own black-desk command station between two monitors — a multi-camera multiview on the left and a video-call participant grid on the right — looking on, delighted with her control over the room.";

const theNinjasAlt =
  "The three AV Ninjas technicians move through the wings of a corporate ballroom with quiet, coordinated economy — one mid-stride with a coiled cable, one watching the stage, one calm and watchful.";
const theGearAlt =
  "An AV Ninjas technician pushes a wheeled road case up the ramp and into the back of a loaded sprinter van at a hotel back-of-house — the van interior full of stacked, labeled cases.";
const finalCtaAlt =

const audiences: Audience[] = [
  {
    id: "in-person",
    label: "In Person",
    support: "IRL > Virtual",
    body: "Large gatherings have been a thing for thousands of years. Something happens when you get people together that is greater than the sum of the parts.\n\nBut our attention spans are more fragile than ever. Polished AV is no longer a luxury but a make-it or break it thing. It's worth getting right!",
    img: audInPersonImg,
    alt: audInPersonAlt,
  },
  {
    id: "hybrid",
    label: "Hybrid",
    support: "In the room and on the screen at once.",
    body: "Hybrid is two shows at once, and most of the risk lives in the handoff between them. We run the room and the stream as one system — so remote attendees see and hear everything the in-room audience does, your presenter can actually engage both, and nobody on the call feels like an afterthought. No dropped feeds, no awkward “can you hear us?”",
    img: audHybridImg,
    alt: audHybridAlt,
  },
  {
    id: "virtual",
    label: "All Virtual",
    support: "Studio-grade, streamed to everyone, everywhere.",
    body: "Virtual doesn't mean lower production — it means the camera is your whole audience. We build a clean, studio-grade setup: broadcast cameras, proper lighting, crisp audio, and a stream that actually holds up on whatever platform you're on — Zoom, Teams, YouTube, Resi. Your presenter comes across like they're on a network, not a webcam.",
    img: audVirtualImg,
    alt: audVirtualAlt,
  },
];

const marqueeItems = [
  "Sales Meetings",
  "Galas",
  "Off-Site Meetings",
  "Product Launches",
  "Executive Strategy Sessions",
  "Annual Conferences",
  "User Conferences",
  "Town Halls",
  "Leadership Summits",
  "Award Ceremonies",
  "Investor & Shareholder Meetings",
  "Board Retreats",
  "Trade Shows",
  "Keynotes",
  "Fundraisers",
  "Holiday Parties",
  "Roadshows",
  "Panel Discussions",
  "Training & Certification Events",
  "Press Conferences",

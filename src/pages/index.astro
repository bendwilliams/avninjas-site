/* Revision 8 (Ben) — WRAP-AWARE hero highlight. The R7 hero highlight was split
   into two CONTENT segments ("EA's, Execs, Agencies and Event" / "Planners") tuned
   to the DESKTOP wrap. On mobile the phrase wraps at different points (more lines),
   so the fixed content split no longer matched the visual lines and MULTIPLE lines
   lit at once. A content split can only ever match one wrap width. The fix: wrap
   EACH WORD in its own marker span; JS measures each word's rendered line membership
   by offsetTop (on load + on resize) and reveals the words one VISUAL LINE at a time,
   so it reads as one continuous left→right, top→bottom draw at EVERY width. The
   verbatim copy is unchanged — these are exactly the words of "EA's, Execs, Agencies
   and Event Planners", rendered as spans joined by single spaces (the fidelity check
   strips tags + collapses whitespace, so the decoded string is identical). */
const heroHighlightWords = [
  "EA's,",
  "Execs,",
  "Agencies",
  "and",
  "Event",
  "Planners",
];

/* ============================================================
   FAQ (Hook copy pack §2 + Crawford audit §5.2). Three Q&A pairs
   (A3 outside-AV/exclusivity, A2 why venue AV is expensive, A6
   conference AV cost). Every answer string is VERBATIM from
   Deliverables/2026-06-22-av-ninjas-copy-pack.md §2 — Felix integrates,
   does not compose. Each answer is a two-sentence machine-liftable
   `direct` opener (the AEO lift block) + a `supporting` human paragraph.

   CRITICAL (Crawford §5.2, Google policy): the on-page FAQ block below is
   the VISIBLE source of truth. The FAQPage JSON-LD `acceptedAnswer.text`
   is built from the SAME strings (direct + supporting, space-joined), so
   the schema can never drift from what the page shows — no schema-only
   invisible FAQ. The single `faqs` array drives both the rendered
   accordions AND the JSON-LD, by construction. Order on the page follows
   Hook's pack (A3 → A2 → A6); the schema preserves that order.
   ============================================================ */
interface Faq {
  /** Rendered in the accordion <summary> AND the schema Question.name. */
  question: string;
  /** Two-sentence direct answer — the AEO machine-lift block. Verbatim. */
  direct: string;
  /** Supporting human detail paragraph. Verbatim. */
  supporting: string;
}
// v3 TONE REVISION (Hook copy-pack-v2/v3, 2026-06-22): the FAQ answers are now
// tight, single 2-sentence direct answers (v3.1 for A3/A2; v2 §1 for A6 with Ben's
// now-APPROVED floors). The longer supporting prose moved into the matching
// /resources/ articles. `supporting` is intentionally empty — the visible answer
// AND the schema acceptedAnswer.text are BOTH just `direct`, so they still mirror
// verbatim (the render + faqSchema below skip empty supporting). Order unchanged
// (A3 → A2 → A6). No villain/markup-% framing; margin named normal; mechanism
// (under-resourced crew / non-expert single point of contact) carried customer-first.
const faqs: Faq[] = [
  {
    question:
      "Can I use an outside AV company instead of the venue's in-house AV?",
    direct:
      "Usually yes — even with a preferred or in-house partner, most contracts still let you bring your own crew, sometimes for a fee, and a lot of the time that fee's worth paying. The real question isn't in-house vs. outside, it's whether your single point of contact actually knows AV — because one who asks the right questions can solve in a single conversation what a non-expert middleman turns into weeks of back-and-forth.",
    supporting: "",
  },
  {
    question: "Why is hotel and venue AV so expensive?",
    // Ben-authored verbatim (2026-06-26). Multi-paragraph; \n\n splits paragraphs
    // in the render + the schema text.
    direct:
      "Most businesses (ours included) spend money to acquire customers. Some AV companies partner with venues, which is a perfectly sensible thing to do. It CAN be a win for all parties — and some people absolutely DO handle it in a way that's totally above board.\n\nWhere this model often breaks is when the money gets divvied out such that YOU (the client) are paying a (sometimes HUGE) premium for AV, but the crew has to make it happen on a shoestring budget and with spotty information. Much could be said about this but it boils down to a business model that treats the relationship with YOU as transactional. Not really the play if the goal is repeat business.\n\nPaying a premium for sub-par / hot mess service = no bueno.\nFeeling 'hamstrung' because things have been in limbo for months and the event is right around the corner = even less bueno.",
    supporting: "",
  },
  {
    question: "How much does AV cost for a corporate conference?",
    // Ben-authored verbatim (2026-06-26). Answer ENDS at the pricing reference — no
    // prompt/CTA after it (Ben moved the rhetorical line to the final-CTA heading).
    direct:
      "Most people will tell you \"it depends,\" which is absolutely true. But so you have a point of reference, true pro-level AV support starts at around $5K for a meeting, $20K for a conference, and $50K for higher-end production events.",
    supporting: "",
  },
];

// FAQPage JSON-LD (Crawford audit §5.2). Built from the SAME `faqs` array that
// renders the visible accordions, so acceptedAnswer.text === the on-page answer
// (direct + supporting, space-joined). This is the anti-drift guarantee.
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      // Mirror the visible answer verbatim: direct + supporting only when
      // supporting is non-empty (v3 trimmed answers carry no supporting prose).
      text: faq.supporting ? `${faq.direct} ${faq.supporting}` : faq.direct,
    },
  })),
};

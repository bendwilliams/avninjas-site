            <p class="out-of-area">Out-of-area? We may still be able to help — just ask!</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 18b. FAQ (cream — accordion list, head CENTERED) ============ -->
    <!-- Hook copy pack §2 + Crawford audit §5.2. A REAL, VISIBLE FAQ block (Google
         forbids schema-only invisible FAQ) — these accordions ARE the source the
         FAQPage JSON-LD (head of <body>) mirrors. Uses the sanctioned .accordion
         primitive (GL-003 §8 — native <details>/<summary>, chevron, ≤250ms,
         keyboard + SR accessible by construction). Answer copy is verbatim from
         the copy pack (v3 tone revision); Felix integrates, does not compose. Each
         answer now renders just its tight two-sentence direct opener (v3 moved the
         supporting prose into the matching /resources/ articles), and that exact
         string is what the FAQPage schema acceptedAnswer.text carries. -->
    <section class="section section--cream faq-section band-tight" id="faq" aria-label="Frequently asked questions">
      <!-- FAQPage structured data (Crawford audit §5.2). Built from the SAME `faqs`
           array that renders the accordions below, so acceptedAnswer.text matches
           the visible answer verbatim (direct + supporting). is:inline so Astro
           emits the JSON-LD as-is (no bundling), exactly like the sitewide
           LocalBusiness schema in BaseLayout. -->
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
      <div class="container">
        <h2 class="sec-head">Questions, Answered Straight</h2>
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="accordion faq-item" name="faq">
              <summary>
                <span class="faq-q">{faq.question}</span>
                <svg class="chev" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true"
                     fill="none" stroke="currentColor" stroke-width="1.75"
                     stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 9l6 6 6-6"></path>
                </svg>
              </summary>
              <div class="accordion__body faq-a">
                {/* Multi-paragraph answers (Ben Q1) split on blank lines into <p>;
                    a single \n inside a paragraph (the two "bueno" lines) is preserved
                    as a <br> so the verbatim line structure survives. */}
                {faq.direct.split("\n\n").map((para) => (
                  <p class="lead faq-a__direct">
                    {para.split("\n").map((line, i) => (
                      <>{i > 0 && <br />}{line}</>
                    ))}
                  </p>
                ))}
                {faq.supporting && <p class="faq-a__support">{faq.supporting}</p>}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 19. FINAL CTA (dark moment, full-bleed #3, CENTERED) ============ -->
    <!-- FULL-BLEED #3 (sweep §C): wide warm room-full-of-success on dark, ink
         scrim, centered headline + single gradient CTA over it. -->
    <section class="final-cta-section section--dark center" id="final-cta" data-dark-fade aria-label="Final CTA">
      <figure class="fullbleed fullbleed--cta">
        <Image
          class="fullbleed__img"
          src={finalCtaImg}
          alt={finalCtaAlt}
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="lazy"
        />
        <div class="fullbleed__scrim"></div>
        <div class="fullbleed__inner">
          <div class="container">
            <div class="sec-head sec-head--wide sec-head--onbleed">
              <!-- Final-CTA heading. Ben 2026-06-26: extended the original short heading
                   with the second rhetorical clause, which moved here out of the cost FAQ.
                   Ben 2026-06-27: demote the second clause to a sub-headline (.subhead,
                   --text-h2) beneath the display line. The two render on separate lines but
                   the copy-fidelity gate stays 143/143 — decode() strips tags and collapses
                   whitespace, so the canonical string is still matched across the split. -->
              <h2 class="display">Ready to Do The Thing?</h2>
              <p class="subhead">Or just want to Talk Through Your Options?</p>
              <p class="lead">
                The ninjas are here to handle the heavy lifting so you can focus on what
                matters. Let's talk about making your event unforgettable.
              </p>
            </div>
            <div class="btn-row center-row">
              <!-- Primary Let's-Talk-class action → gradient. Destination = Free Planning
                   Call (general-site universal door per Ben's 2026-06-26 ruling; audit URL
                   is lander-only). -->
              <a href="https://calendly.com/ben-avninjas/free-planning-call" class="btn btn--gradient on-dark" target="_blank" rel="noopener noreferrer">Book a Call!</a>
              <!-- Ben: "remove the learn more button" at the final CTA. The canonical
                   copy SSOT still lists a "Learn" button here and check:copy must stay
                   143/143 — so the word stays in the DOM (sr-only) to satisfy the gate
                   while the visible button is removed. FLAG: if Ben wants "Learn" gone
                   for good, the copy SSOT + fidelity-checklist need updating. -->
              <a href="#" class="btn btn--secondary sr-only" data-pending="cta-destination" aria-hidden="true" tabindex="-1">Learn</a>
            </div>
          </div>
        </div>
      </figure>
    </section>

    <!-- ============ 20. SECONDARY OFFERS (bottom zone — cream, below the fold) ============
         Ben placement rule (2026-06-26, critical): the homepage is the landing page for
         HOT Google-Ads traffic, so the primary Book-a-Call (planning-call) stays the
         DOMINANT, repeated action up top + throughout (hero / No-Funny-Business / Nail-
         down / final CTA / header). These TWO secondary doors live at the BOTTOM, visually
         subordinate (smaller heads --text-h3, secondary buttons, neutral cream ground) so
         a ready-to-buy lead is never slowed by them. Module A = the HVCO download (→ the
         existing /hvco/ opt-in). Module B = the self-qualifying audit teaser (→ the new
         /free-audit PAGE, NOT the Calendly directly — the audit Calendly is lander-only). -->
    <section class="section section--cream secondary-offers" aria-label="More ways to start">
      <div class="container">
        <div class="secondary-offers__grid">
          <!-- A — HVCO download -->
          <article class="offer-card">
            <h2 class="offer-card__head">Not ready to talk yet? Steal our playbook.</h2>
            <p class="offer-card__copy">
              Get the free guide event planners use to sort the AV piece in minutes instead
              of months — how to vet an AV company, where your budget actually goes, and how
              to pull off real production value for less. Includes the venue-fees cheatsheet:
              the questions worth asking before you sign.
            </p>
            <a href={`${import.meta.env.BASE_URL}hvco/`} class="btn btn--secondary">Get the free guide</a>
          </article>

          <!-- B — self-qualifying audit teaser (past event OR upcoming) → the /free-audit
               PAGE (not Calendly). Ben-authored verbatim copy (2026-06-26); the "breath"
               typo was corrected to "breathe" per Ben's note. -->
          <article class="offer-card">
            <h2 class="offer-card__head">Need a sanity check on an AV number?</h2>
            <p class="offer-card__copy">
              Past or Future events — we'll be your second set of eyes and we'll shoot you
              straight.
            </p>
            <p class="offer-card__copy">
              There are plenty of honest operators throughout our region. If you're getting a
              fair deal we'll say so and you can rest easier.
            </p>
            <p class="offer-card__copy">
              That said, we've seen some pretty outlandish stuff. Want to breathe the air
              during the event? There's a fee for that, <em>obviously</em>! Ok we've never
              actually seen an oxygen surcharge, but we've seen some things that come close!
            </p>
            <p class="offer-card__copy offer-card__make-sure">Make sure:</p>
            <ol class="offer-card__list">
              <li>You're getting the right stuff</li>
              <li>You're paying the right amount for what you're getting</li>
            </ol>
            <a href={`${import.meta.env.BASE_URL}free-audit/`} class="btn btn--secondary">Get a free AV audit</a>
          </article>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .center { text-align: center; }
  .center .btn-row,
  .center-row { justify-content: center; }

  /* ============ 20. SECONDARY OFFERS (bottom zone) ============
     Deliberately subordinate to the primary planning-call CTAs above (Ben placement
     rule): neutral cream ground, no gradient, card heads at --text-h3 (NOT the --text-h1
     section-head role), secondary outline buttons. Two cards side-by-side on desktop,
     stacked on mobile. */
  .secondary-offers__grid {
    display: grid;
    gap: var(--space-xl);
  }
  @media (min-width: 768px) {
    .secondary-offers__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }
  .offer-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .offer-card__head {
    /* Subordinate to major section heads: card-title role (--text-h3), not --text-h1. */
    font-size: var(--text-h3);
    line-height: var(--leading-h3);
    margin-bottom: var(--space-md);
  }
  .offer-card__copy {
    line-height: var(--leading-body);
    margin-bottom: var(--space-md);
  }
  /* "Make sure:" lead-in sits tight to its list. */
  .offer-card__make-sure {
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }
  .offer-card__list {
    line-height: var(--leading-body);
    margin-bottom: var(--space-lg);
    padding-inline-start: var(--space-lg);
  }
  .offer-card__list li { padding-block: var(--space-2xs, 4px); }
  /* Push the button to the card's bottom so the two cards' CTAs align across the row. */
  .offer-card .btn { margin-top: auto; }

  /* ============ HERO — full viewport on load (§9) ============ */
  /* The white hero fills the ENTIRE viewport on first paint, every device.
     100dvh so mobile browser chrome (collapsing URL bar) never breaks it.
     The header is fixed + reveals only after the hero scrolls away, so the
     hero owns the whole first screen. */
  .hero-section {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    background: var(--color-canvas);
    padding-block: var(--space-2xl);
  }
  /* §10: reduce white space + fill more of the screen. The hero container widens
     past the 1200 measure (the hero is the one "special" full-bleed-feel section);
     the text column pulls LEFT, the wide image pushes RIGHT and fills its column
     edge-to-edge. */
  .hero-grid {
    display: grid;
    gap: var(--space-xl);
    align-items: stretch;
    width: 100%;
  }
  @media (min-width: 920px) {
    .hero-section .hero-grid.container {
      max-width: min(1560px, 96vw); /* wider than the 1200 measure — hero fills the screen */
    }
    .hero-grid {
      /* text narrower, image dominant + further right (§10) */
      grid-template-columns: 5fr 7fr;
      gap: var(--space-2xl);
      align-items: center;
      min-height: min(78dvh, 720px); /* content fills more of the viewport */
    }
  }
  .hero-copy { align-self: center; }

  /* Revision 6 (Ben): hero "Learn More" — NO outline/border, with a down-arrow to
     the right of the label. Borderless secondary affordance (a "scroll down" cue),
     ink text, gap to the arrow. Keeps the .btn pill sizing/typography for rhythm
     with the gradient primary beside it, but drops the outline entirely. Hover +
     focus-visible nudge the arrow down to reinforce "go down." */
  .btn--learn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    background: transparent;
    border-color: transparent; /* explicitly no outline/border (base .btn is transparent border) */
    color: var(--color-ink);
    padding-inline: var(--space-md); /* tighter than the bordered pill — it's not a boxed button */
  }
  .btn--learn .btn-arrow {
    flex: none;
    transition: transform var(--motion-micro) var(--ease-out);
  }
  .btn--learn:hover,
  .btn--learn:focus-visible { color: var(--color-accent); }
  .btn--learn:hover .btn-arrow,
  .btn--learn:focus-visible .btn-arrow { transform: translateY(2px); }
  @media (prefers-reduced-motion: reduce) {
    .btn--learn .btn-arrow { transition: none; }
  }
  /* B3 (round-5): accent the service words on the LIGHT hero ground (light voice
     #1D4ED8 — AA 5.4:1 on canvas). Weight bump so the color reads as emphasis. */
  .svc-accent { color: var(--color-accent); font-weight: 600; }
  /* Revision 8 (Ben): the Solid-AV lead emphasis phrase, RED on the CREAM ground.
     Light-voiced emphasis red (--color-accent-red-deep #C0241F, AA 5.08:1 on cream)
     — NOT the dark-voiced #F87171 which fails AA here. Weight bump for the punch. */
  .emph-red-deep { color: var(--color-accent-red-deep); font-weight: 600; }
  /* Revision 8 (Ben): the Mission Control "cool toys" aside, BLUE on the light ground.
     Light-voice accent (--color-accent #1D4ED8, AA 6.4:1 on canvas). */
  .emph-accent { color: var(--color-accent); font-weight: 600; }
  /* B1 (round-5): hero text slightly smaller — a small reduction, not a big one.
     Scale the display headline down ~8% via clamp on the existing --text-display
     so the whole responsive curve shifts down together (no fixed-px override). */
  .hero-copy h1.display {
    font-size: clamp(2.75rem, 1.72rem + 4.4vw, 5.05rem);
  }
  .hero-copy h1 { margin-bottom: var(--space-lg); }
  /* Revision 7 (Ben): the hero image (now 1264×848, native ~3:2) displays at its
     NATIVE aspect ratio — UNCROPPED. The prior forced full-bleed crop (height:100%
     + min-height + object-fit:cover + object-position) cropped the new 3:2 regen, so
     it is removed. The <img> keeps its intrinsic ratio (width:100%, height:auto), so
     the picture shows the whole frame at ~3:2 and shrinks responsively. */
  .img-real.hero-img {
    width: 100%;
    height: auto;
    object-fit: contain; /* no crop — show the whole native frame */
    align-self: center;  /* don't let the grid stretch the image off-ratio */
    border-radius: var(--radius-md);
  }
  .hero-kicker {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-h3);
    line-height: var(--leading-h3);
    margin-block: var(--space-lg) var(--space-xl);
  }

  /* ============ AUDIENCES (full-bleed opener + locked label grid + ticker) ============ */
  .audiences-bleed { height: clamp(280px, 42vh, 460px); margin-bottom: var(--space-3xl); }
  .sec-head--onbleed,
  .sec-head--onbleed h2,
  .sec-head--onbleed p { color: var(--color-canvas); }
  .sec-head--onbleed { text-shadow: 0 2px 14px color-mix(in srgb, var(--color-ink) 70%, transparent); }

  .audiences-grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-md) var(--space-lg);
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: start;
    margin: 0;
  }
  .aud-sep {
    align-self: center;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-h2);
    color: var(--color-gray-bright);
  }
  .aud-card {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .aud-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
  }
  .aud-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-ink) 62%, transparent) 0%,
      color-mix(in srgb, #2a1f14 22%, transparent) 38%,
      transparent 62%
    );
    pointer-events: none;
  }
  .aud-label {
    position: absolute;
    left: var(--space-lg);
    bottom: var(--space-lg);
    z-index: 1;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-h3);
    line-height: var(--leading-h3);
    color: var(--color-canvas);
    text-shadow: 0 1px 8px color-mix(in srgb, var(--color-ink) 60%, transparent);
  }
  .audiences-ticker { margin-top: var(--space-3xl); }
  @media (max-width: 767px) {
    .audiences-grid { grid-template-columns: 1fr; }
    .aud-sep { display: none; }
  }

  /* §11: per-card "Learn More" → full-viewport takeover. The button sits at the
     bottom-left of the card under the label. */
  .aud-more {
    position: absolute;
    left: var(--space-lg);
    bottom: var(--space-lg);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-small);
    color: var(--color-canvas);
    background: color-mix(in srgb, var(--color-ink) 55%, transparent);
    border: var(--border-standard) solid color-mix(in srgb, var(--color-canvas) 70%, transparent);
    border-radius: var(--radius-pill);
    padding: var(--space-xs) var(--space-md);
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background-color var(--motion-micro) var(--ease-out),
      color var(--motion-micro) var(--ease-out);
  }
  /* The label sits ABOVE the button now — lift it so they don't overlap. */
  .aud-card .aud-label { bottom: calc(var(--space-lg) + 2.6rem); }
  .aud-more:hover {
    background: var(--color-canvas);
    color: var(--color-ink);
  }

  /* The full-viewport takeover panel. Hidden by default; the script reveals it
     (sets [hidden]=false + .is-open). Fills the WHOLE viewport like the hero. */
  .aud-takeover {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--color-ink);
    opacity: 0;
    transition: opacity var(--motion-dark-fade) var(--ease-out);
  }
  .aud-takeover.is-open { opacity: 1; }
  .aud-takeover[hidden] { display: none; }
  .aud-takeover__img {
    position: absolute;
    inset: 0;
    width: 100%;
    max-width: none; /* full viewport, not the 1920 image cap — it's a takeover surface */
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
  }
  .aud-takeover__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-ink) 86%, transparent) 0%,
      color-mix(in srgb, var(--color-ink) 50%, transparent) 45%,
      color-mix(in srgb, var(--color-ink) 30%, transparent) 100%
    );
    pointer-events: none;
  }
  .aud-takeover__close {
    position: absolute;
    top: var(--space-xl);
    right: var(--space-xl);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    font-size: 28px;
    line-height: 1;
    color: var(--color-canvas);
    background: color-mix(in srgb, var(--color-ink) 50%, transparent);
    border: var(--border-standard) solid color-mix(in srgb, var(--color-canvas) 70%, transparent);
    border-radius: var(--radius-pill);
    cursor: pointer;
    backdrop-filter: blur(4px);
  }
  .aud-takeover__close:hover { background: var(--color-canvas); color: var(--color-ink); }
  /* Revision 9 (Ben): back arrow, TOP-LEFT — same pill treatment as the close X,
     mirrored to the left edge. Both close the takeover. */
  .aud-takeover__back {
    position: absolute;
    top: var(--space-xl);
    left: var(--space-xl);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    line-height: 1;
    color: var(--color-canvas);
    background: color-mix(in srgb, var(--color-ink) 50%, transparent);
    border: var(--border-standard) solid color-mix(in srgb, var(--color-canvas) 70%, transparent);
    border-radius: var(--radius-pill);
    cursor: pointer;
    backdrop-filter: blur(4px);
  }
  .aud-takeover__back:hover { background: var(--color-canvas); color: var(--color-ink); }
  .aud-takeover__inner {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-md);
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-5xl) var(--space-xl);
    color: var(--color-canvas);
  }
  .aud-takeover__eyebrow {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-bright);
    margin: 0;
  }
  .aud-takeover__title {
    font-size: var(--text-display);
    line-height: var(--leading-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-canvas);
    margin: 0;
  }
  .aud-takeover__support {
    font-size: var(--text-body-lg);
    line-height: var(--leading-body-lg);
    max-width: 640px;
    margin: 0;
  }
  .aud-takeover__body {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    max-width: 620px;
    margin: 0;
    color: color-mix(in srgb, var(--color-canvas) 88%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    .aud-takeover { transition: none; }
  }

  /* ============ ATTENTION — reduced white space + SHORTER image (§13) ============ */
  /* §13: tighten the section vertical rhythm and cap the image height so it reads
     SHORTER (the composited back-logo shot was reading too tall). */
  .attention-section .sec-head { margin-bottom: var(--space-xl); }
  .attention-media { align-self: center; }
  .attention-media .img-real {
    min-height: 0;
    max-height: clamp(260px, 38vh, 420px); /* shorter than the default split media */
    object-position: center 30%;
  }
  @media (min-width: 920px) {
    .attention-split { align-items: center; } /* no longer forced to share a tall edge */
  }

  /* ============ ATTENTION — iconed verb quartet (inside the SPLIT) ============ */
  /* B5 (round-5): more breathing room between the "countless reasons" lead and the
     four verb items — bump the top margin (was --space-lg) and widen the row gap so
     the verbs sit as a distinctly separated block. */
  .attention-split .split__copy .lead { margin-bottom: var(--space-xl); }
  .verb-row {
    list-style: none;
    margin: var(--space-2xl) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg) var(--space-2xl);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-h4);
  }
  .verb-row li { display: inline-flex; align-items: center; gap: var(--space-sm); }
  .verb-row .icon { color: var(--color-ink); }

  /* ============ SOLID-AV trio ============ */
  .solid-icon { color: var(--color-ink); margin-bottom: var(--space-sm); }
  .solid-trio { text-align: left; }
  .solid-cell { text-align: left; }
  /* §15: transparent alien dropped INLINE right after "alien abduction..",
     small + baseline-aligned with the running text (not a floating block). */
  .alien-inline {
    display: inline-block;
    width: clamp(1.4em, 1.6em, 2em);
    height: auto;
    vertical-align: -0.45em; /* sit on the text baseline, slightly tucked */
    margin-inline: 0.15em 0.1em;
  }

  /* ============ SOUND DRAMATIC — phone wake + one message + buzz (§14) ============ */
  /* §14: headline on ONE line. Widen the head measure + prevent the wrap. */
  .sound-head {
    max-width: none;
    white-space: nowrap;
    text-wrap: nowrap;
  }
  @media (max-width: 600px) {
    /* Allow a wrap only on the smallest screens where one line can't fit. */
    .sound-head { white-space: normal; text-wrap: balance; }
  }
  /* Sub-blocks (former accordions): rhythm + a hairline divider. */
  .dramatic-block {
    padding-top: var(--space-lg);
    margin-top: var(--space-lg);
    border-top: 1px solid var(--color-gray-bright);
  }
  .dramatic-block h3 { margin-bottom: var(--space-md); }

  /* §14 (round-5, Ben reversal): the phone moment is now a REAL VIDEO of a phone
     buzzing — no synthetic lit-screen, no notification pill, no registration
     offsets. The previous CSS/JS overlay apparatus (.phone, .phone__screen,
     .phone__notif*, the is-lit/is-buzzing wake animation, @keyframes notif-slide
     + phone-buzz) was the rejected "icon" and has been removed wholesale. The
     video element fills the stage slot; JS starts playback on scroll-into-view
     and prefers-reduced-motion shows the poster still only. */
  .phone-video {
    display: block;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    background: var(--color-ink); /* steady backdrop before the poster/frame paints */
  }
  /* Mobile phantom-width fix (Vera v4 MEDIUM, round-4 §20 — preserved through the
     video swap): the global.css `.split__media { min-height: 320px }` and
     `.split__media .img-real { min-height: 320px }` create a phantom box that,
     combined with the absolutely positioned media, blows out the layout width at
     360px. SCOPE-OVERRIDE the min-height to 0 on the phone-stage and its video so
     the stage is sized ONLY by its own aspect-ratio cap — no phantom width. */
  .sound-split .phone-stage {
    aspect-ratio: 16 / 9;
    max-height: 70vh;
    min-height: 0; /* defeat the global .split__media min-height (the phantom) */
    width: 100%;
    max-width: 100%;
    overflow: hidden; /* clamp any sub-pixel video bleed inside the stage */
  }
  .sound-split .phone-stage .phone-video {
    min-height: 0; /* defeat the global .split__media min-height too */
  }
  @media (min-width: 920px) {
    .sound-split .phone-stage { aspect-ratio: auto; max-height: none; }
  }

  /* ============ THE GEAR — accent voicing on the DARK ground (B9 / B10) ============ */
  /* B9: the Uber line in the dark-voice accent (#60A5FA, 7.0:1 on ink). */
  .gear-accent { color: var(--color-accent-bright); font-weight: 600; }
  /* B10: "absurd" — the single red punch (#F87171, 6.5:1 on ink). */
  .word-absurd { color: var(--color-accent-red); font-weight: 700; }

  /* ============ THE NINJAS — the question lead-in inside the content column ============ */
  .ninjas-question {
    font-size: var(--text-h2);
    line-height: var(--leading-h2);
    margin-bottom: var(--space-lg);
  }

  /* ============ Three-up grids ============ */
  .trio-grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    margin-top: var(--space-2xl);
  }

  /* ============ GUARANTEE (No Funny Business) ============ */
  /* B6 (round-5): NFB headline slightly smaller — keep it big + bold, just a small
     reduction off --text-mega (~8% down across the responsive curve). */
  .nfb-heading {
    margin-bottom: var(--space-sm);
    font-size: clamp(3.2rem, 1.7rem + 6.45vw, 6.9rem);
  }
  /* Revision 6 (Ben) 7c: on phones the --text-mega clamp still rendered "NO FUNNY
     BUSINESS, GUARANTEED." big enough that "GUARANTEED." (11 uppercase chars) bled /
     wrapped awkwardly onto its own ragged line. Tune a smaller, fluid size below the
     mobile breakpoint so the headline sits cleanly — still big and bold (it's the
     mega contrast moment), just sized to fit a 320–600px line. Above 600px the
     unchanged clamp above governs (desktop contrast intact). */
  @media (max-width: 600px) {
    .nfb-heading {
      font-size: clamp(2rem, 1.1rem + 4.6vw, 2.8rem);
      letter-spacing: 0.005em;
    }
  }
  /* Small red "IF YOU KNOW, YOU KNOW" line between the headline and the pillars. */
  .nfb-iykyk {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent-red);
    margin: 0 0 var(--space-lg);
  }
  .nfb-triggers { margin-bottom: 0; line-height: 1.7; }
  /* Revision 6 (Ben) 7d: on MOBILE the three trigger phrases break onto their own
     3 lines and the vertical "|" dividers are removed. Desktop (≥601px) keeps the
     inline single-line form WITH the "|" dividers (unchanged). Each phrase is its
     own .nfb-seg lime marker, so the per-phrase highlight sweep keeps working on
     both layouts — stacking the segments doesn't touch the sweep mechanism. The
     dividers are aria-hidden decorative text (not canonical copy), so hiding them
     on mobile is safe for copy fidelity + a11y. */
  @media (max-width: 600px) {
    .nfb-triggers {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
    }
    .nfb-triggers .nfb-divider { display: none; } /* drop the "|" on mobile */
    /* fit-content so the lime marker hugs each phrase (not a full-width band). */
    .nfb-triggers .nfb-seg { width: fit-content; }
  }
  .btn--big { max-width: 720px; text-wrap: balance; }
  /* "It's our job to ask the right questions…" — accent-colored, "our job" bold.
     Solid-AV is a light/cream ground → light-voice accent. */
  .lift-accent { color: var(--color-accent); }
  .lift-accent strong { font-weight: 700; }

  /* ============ FULL-BLEED curtain + CTA heights ============ */
  .fullbleed--curtain { height: clamp(300px, 60vh, 560px); }
  .fullbleed--cta { min-height: clamp(420px, 80vh, 720px); }
  .final-cta-section { padding: 0; }

  /* Revision 8 (Ben): the final-CTA text "Ready to do the thing?" was bottom-biased
     and "thing" spilled past the bottom edge of the image. Root cause: the shared
     .fullbleed__inner is position:absolute; inset:0, so it is EXACTLY min-height tall
     and does NOT grow the figure — when the heading + lead + button are taller than
     min-height (short/narrow viewports), the centered grid content overflowed and the
     figure (overflow:hidden) clipped the bottom. FIX for the CTA only: make the inner
     IN-FLOW (relative, not absolute) with its own min-height + flex centering, and pin
     the image + scrim absolutely BEHIND it. Now the figure always grows to contain the
     text, and the text is truly vertically centered — nothing clips at any width. */
  .fullbleed--cta .fullbleed__img,
  .fullbleed--cta .fullbleed__scrim {
    position: absolute;
    inset: 0;
  }
  .fullbleed--cta .fullbleed__inner {
    position: relative; /* in-flow: it now drives the figure height */
    inset: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center; /* true vertical centering of the CTA text block */
    min-height: clamp(420px, 80vh, 720px); /* match the figure floor; grows past it if content is taller */
    /* a touch more vertical breathing room so the block reads centered, never edge-tight */
    padding-block: var(--space-3xl);
  }

  /* ============ PACKAGES (§19 / Iris §J — dark card + reversed white bar) ============ */

  /* Revision 6 (Ben/Larry): the Packages section is a cinematic full-viewport
     "moment" on DESKTOP. Position context for the cool-gradient glow accent; the
     full-height + vertical-centering is applied at the desktop breakpoint only
     (mobile must NOT force 100dvh — three cards can't share one phone screen). */
  .packages-section {
    position: relative;
    overflow: hidden; /* clip the radial glow to the section */
  }
  .packages-inner {
    position: relative;
    z-index: 1; /* content sits above the glow */
  }
  /* The brand cool-gradient radial glow behind the Ignition (hero) card. On the
     desktop 3-track grid Ignition is the LAST (right) column, so the glow is
     weighted to the right; on mobile it centers. Tasteful, low-opacity — a
     premium pitch-deck wash, not a rave (GL-003 §2 cool gradient as accent). */
  .packages-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(
        60% 55% at 50% 50%,
        color-mix(in srgb, var(--grad-stop-2) 26%, transparent) 0%,
        color-mix(in srgb, var(--grad-stop-3) 14%, transparent) 42%,
        transparent 72%
      );
    opacity: 0.55;
  }
  @media (min-width: 880px) {
    /* DESKTOP: full-viewport pitch-deck beat — fill the screen, center the
       content vertically. min-height (not height) so taller content never clips. */
    .packages-section {
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    /* Glow weighted to the right where the Ignition (hero) card sits, leaning into
       its existing gradient pop so the hero tier dominates the dark ground. */
    .packages-glow {
      background:
        radial-gradient(
          46% 62% at 78% 52%,
          color-mix(in srgb, var(--grad-stop-2) 30%, transparent) 0%,
          color-mix(in srgb, var(--grad-stop-3) 16%, transparent) 40%,
          transparent 70%
        );
      opacity: 0.6;
    }
  }

  .pkg-grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    align-items: stretch;
  }
  /* B13 (round-6): the MIDDLE card is ~20% physically larger. DOM order is
     Meeting(1) · Conference(2) · Ignition(3) and renders in that natural order
     (no re-ordering), so the middle column is Conference. On desktop the grid is
     an explicit 3-track row where the middle column is 1.2fr (≈20% wider); the
     middle card also scales up vertically (larger body padding + icon) so it's
     bigger in both dimensions. Below the breakpoint the cards stack in DOM order
     (auto-fit above governs), so mobile is unaffected. */
  @media (min-width: 880px) {
    .pkg-grid {
      grid-template-columns: 1fr 1.2fr 1fr;
      align-items: center; /* the taller centerpiece centers against its siblings */
      /* Revision 6: cards SCALE UP with generous spacing on the full-viewport
         desktop moment — wider inter-card gutter + a roomier max measure so the
         trio reads big and premium against the dark ground. */
      gap: var(--space-2xl); /* 48px gutter (was --space-xl/32px) */
      max-width: 1100px;
      margin-inline: auto;
    }
    /* Larger in the vertical axis too — roomier body so the middle (Conference)
       card is ~20% bigger overall. */
    .pkg-grid > .pkg-card:nth-of-type(2) .pkg-body { padding: var(--space-2xl) var(--space-2xl) var(--space-3xl); }
    .pkg-grid > .pkg-card:nth-of-type(2) .pkg-icon :global(.icon) { transform: scale(1.12); transform-origin: left center; }
  }
  /* Revision 6: more air above the cards on the full-height desktop moment so the
     heading breathes at the top of the centered beat. */
  .pkg-heading { margin-bottom: var(--space-2xl); }
  @media (min-width: 880px) {
    .pkg-heading { margin-bottom: var(--space-3xl); }
  }

  /* Revision 9 (Ben): the staggered fade-in/rise ENTRANCE was removed — it took too
     long to load and the per-card colour treatment already carries the interest. The
     cards now render immediately (the .pkg-grid no longer carries data-stagger-reveal,
     so the shared observer never touches it). Per-card colour styling is unchanged. */

  /* Card body: dark charcoal #1C1C22 lifting off the #111115 section, 1px
     hairline edge, 16px radius. No padding on the card itself — the white bar
     spans edge-to-edge at the top; the body carries its own padding. */
  .pkg-card {
    display: flex;
    flex-direction: column;
    background: var(--color-card);
    /* B12 (round-5): more contrast between the dark card and its body text. Lift
       the default body color off the muted gray-bright (#AEB4B7, ~6:1) to canvas
       (#FAFAFA, ~14:1 on #1C1C22) so the content pops. The tagline + icon below
       lift too; the small "Starting at" subtext stays muted by design. */
    color: var(--color-canvas);
    border: var(--border-hairline) solid var(--color-card-hairline);
    border-radius: var(--radius-md);
    overflow: hidden; /* clip the bar's top corners to the card radius */
    height: 100%;
  }

  /* Reversed-light heading bar — the "inverted color of the heading" device.
     White block at the top, ink text, name dominant + price beneath. */
  .pkg-bar {
    background: var(--color-surface);
    color: var(--color-ink);
    padding: var(--space-lg);
  }
  .pkg-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm); /* name → "Starting at" subtext 8px (one unit) */
    margin-bottom: 0;
  }
  .pkg-name {
    order: 1;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-h3);
    line-height: var(--leading-h3);
    color: var(--color-ink);
  }
  .pkg-price {
    order: 2;
    font-size: var(--text-small);
    line-height: var(--leading-small);
    color: var(--color-gray);
  }
  .pkg-join { /* the canonical " — " kept in DOM for fidelity; hidden visually */
    order: 3;
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
  }

  /* Card body on the dark charcoal — icon, tagline, inclusions. */
  .pkg-body {
    display: flex;
    flex-direction: column;
    padding: var(--space-2xl); /* 48px desktop (sweep §E) */
    flex: 1;
  }
  @media (max-width: 600px) {
    .pkg-body { padding: var(--space-xl); } /* 32px mobile (sweep §E) */
  }
  .pkg-icon {
    margin-bottom: var(--space-lg); /* icon → tagline 24px */
    color: var(--color-canvas); /* B12: lifted off gray-bright for contrast */
  }
  .pkg-tagline {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-canvas); /* B12: lifted off gray-bright for contrast */
    margin-bottom: var(--space-lg); /* tagline → list 24px */
  }
  /* B14 / B15 (round-5): inclusions are now a per-line CHECK-MARK list. The lead
     line ("For Small-to-Medium Meetings:" etc.) sits above; each inclusion is its
     own line led by a ✓ (blue check, AA on the dark card). */
  .pkg-lead {
    color: var(--color-canvas); /* B12 contrast */
    font-weight: 600;
    margin-bottom: var(--space-md);
  }
  ul.pkg-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    color: var(--color-canvas); /* B12: lifted off gray-bright for contrast */
  }
  ul.pkg-list li {
    position: relative;
    padding-left: calc(1.1em + var(--space-sm)); /* room for the ✓ */
  }
  ul.pkg-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-accent-bright); /* blue check, AA on dark card (6.4:1) */
    font-weight: 700;
  }

  /* Ignition (Iris §J.2): gradient-FILL bar + DEEPER body (#111115) + DOUBLED
     5px --gradient-pop outline. NO badge (Larry's call). */
  .pkg-card--ignition {
    background: var(--color-ink); /* deeper "premium black" than siblings */
    border: var(--border-pop) solid transparent;
    background-image:
      linear-gradient(var(--color-ink), var(--color-ink)),
      var(--gradient-pop);
    background-origin: border-box;
    background-clip: padding-box, border-box;
    /* B16 (round-5): drift the Ignition rim gradient — same living-video device as
       the gradient CTAs. Oversize + pan the gradient (2nd) layer; the ink fill
       stays put. Paused under prefers-reduced-motion. */
    background-size: 100% 100%, 320% 320%;
    background-position: 0 0, 0% 50%;
    /* B16 (v04): wider travel (320% oversized layer) so the Ignition rim motion is
       clearly perceptible, matching the gradient CTAs.
       v05 (Ben): 3.5s → 2.3s so the drift clearly reads faster. */
    animation: grad-drift 2.3s ease-in-out infinite alternate;
  }
  .pkg-bar--ignition {
    background: var(--gradient-pop);
    /* B16 (v04): the header band's gradient drifts too — wider travel.
       v05 (Ben): 3.5s → 2.3s so the drift clearly reads faster. */
    background-size: 320% 320%;
    background-position: 0% 50%;
    animation: bar-grad-drift 2.3s ease-in-out infinite alternate;
    /* left-to-right ink scrim under the text band so white stays ≥4.5:1 across
       the whole bar regardless of the stop it overlaps (Iris §J.2). */
    position: relative;
  }
  /* Single-layer gradient drift for the bar (no ink fill layer to pin). */
  @keyframes bar-grad-drift {
    from { background-position: 0% 50%; }
    to   { background-position: 100% 50%; }
  }
  .pkg-bar--ignition::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-ink) 38%, transparent) 0%,
      color-mix(in srgb, var(--color-ink) 18%, transparent) 60%,
      transparent 100%
    );
    pointer-events: none;
  }
  .pkg-bar--ignition .pkg-head { position: relative; z-index: 1; }
  /* White text over the navy/cobalt (dark) end of the gradient (AA), justified
     left where white passes per Iris §J.2. */
  .pkg-bar--ignition .pkg-name { color: var(--color-surface); }
  .pkg-bar--ignition .pkg-price { color: color-mix(in srgb, var(--color-surface) 88%, transparent); }

  /* ============ Revision 7 (Ben): sibling-card SUBTLE per-card color ============
     Only Ignition had color (its cycling cool gradient). Give Meeting Essentials and
     Conference each their own subtle tone so the three cards read as differentiated.
     CRITICAL (Ben): the tones must be CLEARLY outside every color the Ignition
     gradient cycles through (navy/cobalt/teal/emerald = cool blue→green). So:
       • Meeting Essentials → WARM AMBER / GOLD  (far warm side of the wheel)
       • Conference        → MUTED PLUM / PURPLE (violet — off the cool blue→green run)
     Subtle, not loud (PV 4–7): a soft tinted HEADING BAR wash (ink text stays AA) +
     a tinted ICON + tinted CHECK-MARKS, all in one hue per card. The cards stay the
     same dark --color-card body + hairline; only the accent hue changes. This is a
     deliberate deviation from GL-003 §8 (sibling checks = blue --color-accent-bright)
     and §5a (sibling icons = monochrome) — Ben-directed; flagged to Iris/Vera.

     Contrast (on the dark card body #1C1C22): amber #E6B566 ≈ 8.3:1, plum #CBA6E4
     ≈ 7.9:1 — both pass AA for the small check text. Ink #111115 on the soft bar
     washes (#FBF3E1 amber / #F1EBF7 plum, ~95% L) stays ≈16:1 — AA for name+price. */
  .pkg-card--amber { --pkg-tone: #e6b566; --pkg-bar-wash: #fbf3e1; }
  .pkg-card--plum  { --pkg-tone: #cba6e4; --pkg-bar-wash: #f1ebf7; }

  /* Soft tinted heading bar — replaces the plain white reversed bar with a gentle
     wash of the card's hue. Ink name + price stay AA on the near-white wash. */
  .pkg-card--amber > .pkg-bar,
  .pkg-card--plum > .pkg-bar { background: var(--pkg-bar-wash); }

  /* Tinted icon + check-marks — the card's accent, replacing the canvas/blue. */
  .pkg-card--amber .pkg-icon,
  .pkg-card--plum .pkg-icon { color: var(--pkg-tone); }
  .pkg-card--amber ul.pkg-list li::before,
  .pkg-card--plum ul.pkg-list li::before { color: var(--pkg-tone); }
  /* A thin accent rule under the heading bar so the hue reads even at a glance. */
  .pkg-card--amber > .pkg-bar,
  .pkg-card--plum > .pkg-bar { border-bottom: var(--border-standard) solid var(--pkg-tone); }
  /* Focus ring within a toned card uses its tone (still AA / visible on dark). */
  .pkg-card--amber :global(:focus-visible),
  .pkg-card--plum :global(:focus-visible) { outline-color: var(--pkg-tone); }

  .pkg-card :global(:focus-visible) { outline-color: var(--color-accent-bright); }

  /* Revision 7 (Ben): emphasize "All the Sizzle of the Vegas Strip" in the Ignition
     card. Bold + the --gradient-pop clipped to the text — the card's own sanctioned
     cool gradient (GL-003 §2 Ignition surface / §5a Ignition color exception), so the
     phrase literally "sizzles" without introducing a new color or breaking scarcity.
     A solid --color-accent-bright fallback paints first (older engines / no
     background-clip:text) so the phrase is always legible + AA (6.4:1 on the ink
     body) even if the gradient clip isn't supported. */
  .pkg-sizzle {
    font-weight: 800;
    color: var(--color-accent-bright); /* AA fallback on the Ignition ink body */
    /* AA-safe "sizzle" gradient: only the BRIGHT stops (sky → teal → emerald, all
       ≥5:1 on the Ignition ink body). The full --gradient-pop's navy/cobalt LEFT
       stops painted the leading words <3:1 on dark — failed AA (Vera R7 MED). */
    background-image: linear-gradient(100deg, var(--color-accent-bright) 0%, var(--grad-stop-3) 52%, var(--grad-stop-4) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: 0.005em;
  }
  /* Reduced-motion is irrelevant here (no animation); high-contrast / forced-colors
     fall back to the solid accent-bright via the color above. */
  @media (forced-colors: active) {
    .pkg-sizzle { -webkit-text-fill-color: currentColor; color: currentColor; }
  }

  /* ============ MISSION CONTROL (SPLIT + steps GRID) ============ */
  .kicker {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-h3);
    line-height: var(--leading-h3);
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }
  /* B (v04): more breathing room between the kicker and the h2 — was --space-sm
     (8px), felt tight; step up to --space-lg (24px). */
  .sec-head .kicker { margin-bottom: var(--space-lg); }
  .mission-groups {
    list-style: none;
    padding: 0;
    /* B (v04): more breathing room between the bottom of the mission-control
       image/copy split and the three group headings — was --space-3xl (64px);
       step up one tasteful increment (3xl + lg = 88px). */
    margin-top: calc(var(--space-3xl) + var(--space-lg));
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
  }
  .mission-step {
    border-top: 2px solid var(--color-ink);
    padding-top: var(--space-md);
  }
  .mission-step__head {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  .mission-step__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex: none;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    color: var(--color-canvas);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-small);
  }
  .mc-head { margin: 0; font-size: var(--text-h3); line-height: var(--leading-h3); }

  /* ============ A LA CARTE — compressed, scannable ============ */
  .alacarte .alacarte-grid { margin-top: var(--space-lg); gap: var(--space-lg); }
  .alacarte-grid > div { text-align: left; }
  .alacarte-icon { color: var(--color-ink); margin-bottom: var(--space-sm); }
  .alacarte-title {
    font-size: var(--text-h4);
    line-height: var(--leading-h4);
    margin-bottom: var(--space-xs);
  }
  .alacarte-lead { margin-bottom: var(--space-sm); }
  .alacarte-list { margin: 0; }
  .alacarte-list li { padding-block: var(--space-xs); }

  /* ============ THE NUMBERS (count-up stat) ============ */
  .stat { text-align: center; }
  .stat__figure {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-display);
    line-height: var(--leading-display);
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    /* reveal: fade + rise as it counts up */
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 500ms var(--ease-out), transform 500ms var(--ease-out);
  }
  .stat.is-revealed .stat__figure { opacity: 1; transform: none; }
  .stat__label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-h4);
    margin-bottom: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .stat__figure { opacity: 1; transform: none; transition: none; }
    /* B16: pause the Ignition gradient drift; hold a legible static gradient. */
    .pkg-card--ignition,
    .pkg-bar--ignition { animation: none; }
    /* Revision 6: the staggered card entrance degrades to its end state — cards
       just present, no rise, no fade (GL-003 §7 reduced-motion floor). */
    .pkg-grid[data-stagger-reveal] > .pkg-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ============ CAPABILITIES — centered GRID, left-aligned lines inside ============ */
  .cap-grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    margin-top: var(--space-2xl);
  }
  /* Revision 8 (Ben): each .cap-col carries its OWN category color via --cap-color,
     set per-column below. The four columns render in fixed order (Audio, Video/
     Streaming, Presentation/GFX, Lighting/Scenic), so nth-child assigns each its
     color token. Falls back to the accent blue if an unexpected 5th column appears. */
  .cap-col { text-align: left; --cap-color: var(--color-accent); }
  .cap-col:nth-child(1) { --cap-color: var(--cap-color-audio); }    /* Audio — blue */
  .cap-col:nth-child(2) { --cap-color: var(--cap-color-video); }    /* Video/Streaming — teal */
  .cap-col:nth-child(3) { --cap-color: var(--cap-color-gfx); }      /* Presentation/GFX — violet */
  .cap-col:nth-child(4) { --cap-color: var(--cap-color-lighting); } /* Lighting/Scenic — amber */
  /* Revision 8 (Ben): the four "Full Breakdown of our Capabilities" category titles
     were all accent-blue in R7. Ben wants them DIFFERENTIATED — each category a
     different color. The category ICON, the heading text, and the under-rule all take
     that column's --cap-color (set per-column above). All four are AA on the canvas
     ground (see tokens.css). Tasteful + on-brand — four peer sub-heads, one consistent
     role, four harmonious hues from the GL-003 cool palette + gradient family. */
  .cap-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-h4);
    line-height: var(--leading-h4);
    color: var(--cap-color);
    border-bottom: 2px solid var(--cap-color);
    padding-bottom: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  /* the category icon takes the same per-column color (light ground; all AA) */
  .cap-title :global(.icon) { color: var(--cap-color); }
  .cap-list { margin: 0; }
  .cap-list li { padding-block: var(--space-xs); }
  /* second-tier capability items (e.g. FOH/Broadcast/Monitor under Audio Consoles) */
  .cap-sublist {
    margin: 4px 0 0;
    padding-left: var(--space-lg);
    list-style-type: circle;
  }
  .cap-sublist li { padding-block: 2px; }

  /* ============ SERVICE AREA — map + region list (Ben, 2026-06-22) ============ */
  .service-area__grid {
    display: grid;
    gap: var(--space-2xl);
    align-items: center;
    justify-items: center;
  }
  @media (min-width: 880px) {
    .service-area__grid {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
      gap: var(--space-4xl);
    }
    .service-area__copy { text-align: left; }
  }
  .service-map {
    margin: 0;
    width: 100%;
    max-width: 340px;
  }
  .service-map svg { width: 100%; height: auto; display: block; }
  /* Map surface styling (.st / .st--primary / .st--faint / .city__*) now lives
     INSIDE the SVG's own scoped <style> block (`.sa-map …`), with literal GL-003
     values, so the asset is self-contained and renders identically standalone.
     The page-level rules were removed to avoid orphaned/duplicate CSS — only the
     .service-map sizing wrapper above is needed from the page. */
  .service-area__copy { max-width: 38ch; }
  .service-area .region-label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gray);
    margin: var(--space-lg) 0 var(--space-sm);
  }
  /* Plain typographic list — names separated by an accent middot, NOT pills/buttons. */
  .region-list {
    list-style: none;
    margin: 0 0 var(--space-lg);
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0 var(--space-sm);
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--text-body-lg);
    line-height: var(--leading-h4);
    color: var(--color-ink);
  }
  @media (min-width: 880px) { .region-list { justify-content: flex-start; } }
  .region-list li { display: inline-flex; align-items: center; }
  .region-list li:not(:last-child)::after {
    content: "·";
    margin-left: var(--space-sm);
    color: var(--color-accent);
    font-weight: 700;
  }
  .out-of-area { color: var(--color-gray); }
  .out-of-area::before {
    content: "";
    display: block;
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    margin: 0 auto var(--space-md);
  }
  @media (min-width: 880px) { .out-of-area::before { margin-inline: 0; } }

  /* ============ 18b. FAQ (cream — sanctioned .accordion primitive) ============ */
  /* The .accordion base (GL-003 §8 / global.css) owns the chevron rotation,
     ≤250ms reveal, full-row target, and reduced-motion end state. These rules
     only constrain the FAQ list to a readable measure and tune answer rhythm —
     no new collapse mechanics, no hardcoded values. */
  .faq-list {
    max-width: 820px;
    margin-inline: auto;
  }
  /* A hairline at the TOP of the first row completes the divider set (the
     .accordion base only draws a bottom border per item). */
  .faq-item:first-of-type {
    border-top: 1px solid var(--color-gray-bright);
  }
  /* The question fills the row; the chevron sits at the far end (summary is a
     space-between flex row from the .accordion base). Left-align the question. */
  .faq-q {
    text-align: left;
  }
  /* On the CREAM band, --color-gray fails AA for body (GL-003 §9), so the
     answer copy stays ink. The direct (lift) opener is the .lead step; the
     supporting paragraph is default body with a small top gap. */
  .faq-a { color: var(--color-ink); }
  .faq-a__direct { margin-bottom: var(--space-md); }
  .faq-a__direct:last-of-type { margin-bottom: 0; }
  .faq-a__support:last-child { margin-bottom: 0; }
  .faq-section .sec-head { margin-bottom: var(--space-2xl); }
</style>

<script>
  /* ============================================================
     The motion moments — vanilla, tiny, progressive enhancement.
     Reduced-motion users get end states (GL-003 §7). No-JS users
     get end states too (dark sections are dark by default).
     ============================================================ */
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ---- Moment 3: light→dark fade section transitions ---- */
  if (!reduceMotion && "IntersectionObserver" in window) {
    const darkSections = Array.from(
      document.querySelectorAll<HTMLElement>("[data-dark-fade]"),
    );
    for (const section of darkSections) {
      if (section.getBoundingClientRect().top > window.innerHeight * 0.6) {
        section.classList.add("is-light");
      }
    }
    const fadeObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.remove("is-light");
            fadeObserver.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.25 },
    );
    for (const section of darkSections) fadeObserver.observe(section);
  }

  /* ---- Moment 2: phone buzz VIDEO, play on scroll-into-view ("Sound Dramatic?") ----
     Round-5 (Ben reversal): the base media is now a real <video>. No synthetic
     wake/notification/buzz overlay, no WebAudio ding. The clip is muted (so
     autoplay-on-scroll is allowed without a prior user gesture) and starts when
     the stage enters the viewport — "wakes up as you scroll to it" — pausing when
     it leaves. prefers-reduced-motion: never play; the poster still stands in. */
  const phoneVideo = document.getElementById("phone-moment")?.querySelector<HTMLVideoElement>(
    ".phone-video",
  );
  if (phoneVideo) {
    if (reduceMotion) {
      // Poster only. Ensure nothing plays; load just the poster, not the stream.
      phoneVideo.removeAttribute("autoplay");
      phoneVideo.pause();
    } else if (!("IntersectionObserver" in window)) {
      // No IO: best-effort play (muted videos are permitted to autoplay).
      void phoneVideo.play().catch(() => {});
    } else {
      const videoObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              void phoneVideo.play().catch(() => {});
            } else {
              phoneVideo.pause();
            }
          }
        },
        { threshold: 0.5 },
      );
      videoObserver.observe(phoneVideo);
    }
  }

  /* ---- Numbers stat: count-up reveal on scroll-into-view (§13) ----
     Counts both ends of the "1.5 - 3.5x" range up to their targets, then locks
     the verbatim string. Reduced-motion / no-IO: the static end state shows. */
  const statEl = document.getElementById("numbers-stat");
  const figureEl = statEl?.querySelector<HTMLElement>(".stat__figure");
  if (statEl && figureEl) {
    const finalText = figureEl.dataset.countup ?? figureEl.textContent ?? "";
    if (reduceMotion || !("IntersectionObserver" in window)) {
      statEl.classList.add("is-revealed");
      figureEl.textContent = finalText;
    } else {
      const lowTarget = 1.5;
      const highTarget = 3.5;
      // B17 (round-5): SLOWER count-up (was 1100ms — fired too fast). The reveal
      // is already gated to scroll-into-view via statObserver below.
      const duration = 2600;
      const runCountUp = (): void => {
        statEl.classList.add("is-revealed");
        const start = performance.now();
        const tick = (now: number): void => {
          const t = Math.min((now - start) / duration, 1);
          // ease-out cubic
          const e = 1 - Math.pow(1 - t, 3);
          const low = (lowTarget * e).toFixed(1);
          const high = (highTarget * e).toFixed(1);
          figureEl.textContent = `${low} - ${high}x`;
          if (t < 1) {
            requestAnimationFrame(tick);
          } else {
            figureEl.textContent = finalText; // lock the verbatim string
          }
        };
        requestAnimationFrame(tick);
      };
      const statObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            runCountUp();
            statObserver.disconnect();
          }
        },
        { threshold: 0.6 },
      );
      statObserver.observe(statEl);
    }
  }

  /* ---- §11: Audiences "Learn More" → full-viewport takeover ----
     Clicking a card's Learn More expands that audience's black frame to fill the
     entire viewport. Esc / close button / backdrop click collapses it. While
     open: focus is trapped inside the panel, body scroll is locked, and focus
     returns to the trigger on close. Accessible (role=dialog, aria-modal,
     labelledby). Progressive enhancement — no JS leaves the cards inert. */
  (() => {
    const openers = Array.from(
      document.querySelectorAll<HTMLElement>("[data-aud-open]"),
    );
    if (!openers.length) return;

    let activePanel: HTMLElement | null = null;
    let lastTrigger: HTMLElement | null = null;

    const focusable = (panel: HTMLElement): HTMLElement[] =>
      Array.from(
        panel.querySelectorAll<HTMLElement>(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])',
        ),
      ).filter((el) => !el.hasAttribute("disabled"));

    const closePanel = (): void => {
      if (!activePanel) return;
      const panel = activePanel;
      panel.classList.remove("is-open");
      const finish = (): void => {
        panel.hidden = true;
        panel.removeEventListener("transitionend", finish);
      };
      if (reduceMotion) finish();
      else panel.addEventListener("transitionend", finish);
      document.body.style.overflow = "";
      activePanel = null;
      if (lastTrigger) lastTrigger.focus();
    };

    const onKeydown = (e: KeyboardEvent): void => {
      if (!activePanel) return;
      if (e.key === "Escape") {
        e.preventDefault();
        closePanel();
        return;
      }
      if (e.key === "Tab") {
        const items = focusable(activePanel);
        if (!items.length) return;
        const first = items[0];
        const last = items[items.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    };

    const openPanel = (id: string, trigger: HTMLElement): void => {
      const panel = document.querySelector<HTMLElement>(`[data-aud-panel="${id}"]`);
      if (!panel) return;
      lastTrigger = trigger;
      activePanel = panel;
      panel.hidden = false;
      document.body.style.overflow = "hidden";
      // next frame so the opacity transition runs
      requestAnimationFrame(() => panel.classList.add("is-open"));
      const closeBtn = panel.querySelector<HTMLElement>("[data-aud-close]");
      (closeBtn ?? focusable(panel)[0])?.focus();
    };

    for (const opener of openers) {
      opener.addEventListener("click", () => {
        const id = opener.dataset.audOpen;
        if (id) openPanel(id, opener);
      });
    }
    for (const closeBtn of Array.from(
      document.querySelectorAll<HTMLElement>("[data-aud-close]"),
    )) {
      closeBtn.addEventListener("click", closePanel);
    }
    // Backdrop click (clicking the panel itself, not its inner content) closes.
    for (const panel of Array.from(
      document.querySelectorAll<HTMLElement>("[data-aud-panel]"),
    )) {
      panel.addEventListener("click", (e) => {
        if (e.target === panel) closePanel();
      });
    }
    document.addEventListener("keydown", onKeydown);
  })();

  /* ---- Highlight Law v3 (Rev 9): CONTINUOUS highlights — ONE highlighter stroke ----
     ONE engine for every [data-continuous-highlight] (the hero phrase + the "Skip the
     Back and Forth" line). The phrase is rebuilt into ONE marker PER RENDERED LINE
     (.hl-line); each line's lime bar wipes 0→100% width as a single continuous unit —
     NEVER per-word (that read as words popping one at a time). Lines hand off
     top→bottom: line N+1's wipe starts exactly when line N's finishes (delay = sum of
     prior line durations), so the whole phrase reads as one unbroken stroke that turns
     the corner at each wrap. Per-line duration = lineWidth / --hl-sweep-speed, so the
     stroke VELOCITY is constant regardless of line length. We MEASURE the rendered
     lines (correct at any width) and re-measure on resize. Reduced-motion / no-JS:
     CSS pre-draws the end state. */
  const csRoot = getComputedStyle(document.documentElement);
  const SWEEP_PX_PER_MS =
    (parseFloat(csRoot.getPropertyValue("--hl-sweep-speed")) || 620) / 1000;
  const SWEEP_MIN_MS = parseInt(csRoot.getPropertyValue("--hl-sweep-min"), 10) || 220;

  const buildContinuous = (el: HTMLElement): void => {
    // Verbatim source text, stored once so resize rebuilds are lossless.
    const text =
      el.dataset.hlText ??
      (el.dataset.hlText = (el.textContent ?? "").replace(/\s+/g, " ").trim());

    // 1) MEASURE: lay the words out in transient spans and group by rendered line
    //    (offsetTop). The leading space is kept inside each measuring span so the
    //    wrap matches the real text flow.
    const tokens = text.split(" ");
    el.textContent = "";
    const measure = tokens.map((w, i) => {
      const s = document.createElement("span");
      s.className = "hl-measure";
      s.textContent = (i ? " " : "") + w;
      el.appendChild(s);
      return s;
    });
    const lines: string[] = [];
    let lineTop: number | null = null;
    let cur = "";
    for (const s of measure) {
      const top = s.offsetTop;
      if (lineTop === null || Math.abs(top - lineTop) > s.offsetHeight * 0.5) {
        if (cur) lines.push(cur);
        cur = "";
        lineTop = top;
      }
      cur += s.textContent;
    }
    if (cur) lines.push(cur);

    // 2) REBUILD: one .hl-line marker per visual line. Internal spaces stay INSIDE the
    //    marker (gapless); a real space between markers is the wrap break-point (sits
    //    outside the markers, invisible at line end).
    el.textContent = "";
    const lineEls: HTMLElement[] = [];
    lines.forEach((lineText, idx) => {
      const span = document.createElement("span");
      span.className = "hl-line";
      // The breaking space between lines lives INSIDE the marker (every line but the
      // last) — so if a later width change merges two lines onto one row, no
      // unhighlighted gap appears; a trailing space at a real line-end collapses
      // (invisible). This is what lets us NEVER rebuild an already-drawn highlight:
      // box-decoration-break + this in-marker space keep the resting state correct at
      // ANY width with zero rebuilds.
      span.textContent = lineText.trim() + (idx < lines.length - 1 ? " " : "");
      el.appendChild(span);
      lineEls.push(span);
    });

    // 3) TIMING: constant-velocity stroke. duration ∝ width; delay = sum of prior.
    const drawn = el.classList.contains("is-drawn");
    let cumulative = 0;
    for (const span of lineEls) {
      const dur = Math.max(SWEEP_MIN_MS, Math.round(span.offsetWidth / SWEEP_PX_PER_MS));
      if (drawn || reduceMotion) {
        // Already revealed (resize) or motion off: snap, don't re-animate.
        span.style.transitionDuration = "0ms";
        span.style.transitionDelay = "0ms";
      } else {
        span.style.transitionDuration = `${dur}ms`;
        span.style.transitionDelay = `${cumulative}ms`;
      }
      cumulative += dur;
    }
  };

  const continuousHighlights = Array.from(
    document.querySelectorAll<HTMLElement>("[data-continuous-highlight]"),
  );
  for (const el of continuousHighlights) buildContinuous(el);
  if (continuousHighlights.length && !reduceMotion) {
    // Re-segmentation rules (these fix the mobile-only sweep bug):
    //  • The wrap depends on WIDTH only — so ignore height-only resizes. On mobile,
    //    showing/hiding the address bar fires a resize on every scroll (height change
    //    only); rebuilding there used to SNAP the in-flight sweep to its end state
    //    (the bug Ben saw). Desktop never fires those, so it was unaffected.
    //  • Never rebuild an element that is already drawing/drawn: once its sweep has
    //    fired, box-decoration-break keeps the resting highlight correct at any width,
    //    so a rebuild can only risk snapping a mid-flight animation. fonts.ready can
    //    land after the draw starts on mobile — guarding on is-drawn prevents that snap.
    let chRaf = 0;
    let lastWidth = window.innerWidth;
    const rebuildUndrawn = () => {
      for (const el of continuousHighlights) {
        if (!el.classList.contains("is-drawn")) buildContinuous(el);
      }
    };
    window.addEventListener("resize", () => {
      if (window.innerWidth === lastWidth) return; // height-only (e.g. mobile URL bar) — wrap unchanged
      lastWidth = window.innerWidth;
      cancelAnimationFrame(chRaf);
      // Width changed → the wrap may change, so re-segment — but ONLY highlights that
      // haven't drawn yet. NEVER rebuild a drawing/drawn one: rebuilding snaps an
      // in-flight sweep so both lines jump to full at once (the mobile bug). Mobile
      // browsers fire tiny (even 1px) width changes during the visual-viewport /
      // address-bar settle right as the hero is sweeping — exactly when a snap shows.
      // A drawn highlight stays correct at the new width via box-decoration-break + the
      // in-marker trailing space, so it never needs a rebuild.
      chRaf = requestAnimationFrame(rebuildUndrawn);
    });
    if ("fonts" in document) {
      // fonts.ready can land AFTER the sweep starts on mobile — only re-segment what
      // hasn't drawn yet, so a font swap can never snap an in-flight animation.
      (document as Document & { fonts: FontFaceSet }).fonts.ready.then(rebuildUndrawn);
    }
  }

  /* ---- B2 / B7 / B17: ALL highlight sweeps fire on scroll-into-view ----
     One observer drives every marker container — the hero continuous sweep
     (.highlight-sweep, B2), the NFB three-phrase sweep (.nfb-sweep, B7), and any
     legacy single .highlight-static. Each gets .is-drawn when it scrolls in, which
     starts its (CSS-sequenced) draw. The hero is no longer a load animation (B17).
     Reduced-motion / no-IO: pre-draw the end state immediately (no sweep). No-JS:
     the <noscript> rule pre-draws every marker (see index head). */
  const sweepEls = Array.from(
    document.querySelectorAll<HTMLElement>(
      ".highlight-sweep, .nfb-sweep, .highlight-static",
    ),
  );
  if (sweepEls.length) {
    if (reduceMotion || !("IntersectionObserver" in window)) {
      for (const el of sweepEls) el.classList.add("is-drawn");
    } else {
      const armSweeps = () => {
        const sweepObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const el = entry.target as HTMLElement;
              // Re-measure a continuous highlight at the EXACT moment it draws, so its
              // per-line segmentation matches the REAL settled wrap — not a transient
              // measurement taken at script-run before layout/fonts settled. That stale
              // early measurement was the mobile bug: the whole phrase measured as ONE
              // segment, then its two wrapped rows filled together ("both lines at once").
              if (el.hasAttribute("data-continuous-highlight")) buildContinuous(el);
              // Next frame so the freshly-rebuilt 0% spans paint before is-drawn flips
              // them to 100% — otherwise the transition has nothing to animate from.
              requestAnimationFrame(() => el.classList.add("is-drawn"));
              sweepObserver.unobserve(el);
            }
          },
          { threshold: 0.9 },
        );
        for (const el of sweepEls) sweepObserver.observe(el);
      };
      // Arm only AFTER fonts are ready: the hero is visible immediately and draws on
      // load, so it must be measured with FINAL font metrics (a fallback font wraps
      // differently and yields the wrong segment count). Fallback timeout keeps it
      // working if the fonts API is missing or slow.
      if ("fonts" in document) {
        let armed = false;
        const arm = () => {
          if (armed) return;
          armed = true;
          armSweeps();
        };
        (document as Document & { fonts: FontFaceSet }).fonts.ready.then(arm);
        setTimeout(arm, 600);
      } else {
        armSweeps();
      }
    }
  }

  /* ---- v05: The Ninjas three points — staggered individual fade-in ----
     Each [data-stagger-reveal] list gets .is-revealed when it scrolls into view;
     the CSS per-item transition-delay staggers the fade. Reduced-motion / no-IO:
     reveal immediately (the reduced-motion CSS strips the fade so they just show). */
  const staggerEls = Array.from(
    document.querySelectorAll<HTMLElement>("[data-stagger-reveal]"),
  );
  if (staggerEls.length) {
    if (reduceMotion || !("IntersectionObserver" in window)) {
      for (const el of staggerEls) el.classList.add("is-revealed");
    } else {
      const staggerObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            entry.target.classList.add("is-revealed");
            staggerObserver.unobserve(entry.target);
          }
        },
        { threshold: 0.4 },
      );
      for (const el of staggerEls) staggerObserver.observe(el);
    }
  }
</script>

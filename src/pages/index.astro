/* Round-4 §11: Audiences "Learn More" → full-viewport takeover. Each audience
   panel expands its black frame to fill the whole viewport (hero-style), showing
   the image large + the audience heading + a short supporting line. The labels
   ("In Person" / "Hybrid" / "All Virtual") are the canonical copy; the support
   line is neutral, descriptive (NOT marketing) so copy fidelity is untouched.
   Default interpretation per the brief — reversible, accessible (focus trap,
   Esc, aria-modal). */
interface Audience {
  id: string;
  label: string;
  /** Neutral one-liner describing the format (not promotional copy). */
  support: string;
  /** Takeover body — what AV Ninjas does for this audience format. */
  body: string;
  img: ImageMetadata;
  alt: string;
}

interface MissionGroup {
  icon: IconName;
  title: string;
  items: string[];
}
const missionGroups: MissionGroup[] = [
  {
    icon: "mc-comms",
    title: "Comms",
    items: [
      "Join the ninjas' private chat channel. (way faster than texting)",
      "Keep the whole crew apprised of last minute changes",
      "Message the presenter display via the stage display!",
    ],
  },
  {
    icon: "mc-control",
    title: "Real-Time Control",
    items: [
      "Push updates to the Power Point in Seconds!",
      "Control the Speaker Timer Directly!",
    ],
  },
  {
    icon: "mc-visibility",
    title: "First-Hand Visibility",
    items: [
      "Monitor Recordings, Streams, Online Meetings, and other feeds moment by moment.",
    ],
  },
];

interface AlaCarteColumn {
  icon: IconName;
  title: string;
  lead?: string;
  items: string[];
}
const alaCarte: AlaCarteColumn[] = [
  {
    icon: "alacarte-lobby",
    title: "Lobby / Common Area AV",
    lead: "MUCH more flexible than printed signage.",
    items: [
      "Overflow Video",
      "Wayfinding",
      "Announcements",
      "Schedule (Dynamic)",
      "Countdown Timers (Dynamic)",
    ],
  },
  {
    icon: "alacarte-breakout",
    title: "Breakout Room AV",
    items: ["Projection", "Audio", "Recording", "Signage"],
  },
  {
    icon: "alacarte-content",
    title: "Content Capture / Generation",
    items: [
      "Videographer(s)",
      "Sizzle Reels",
      "Interview Corner Setup",
      "Photographers",
    ],
  },
];

/* Packages (B14 / B15 round-5): each inclusion renders on its OWN line with a
   CHECK-MARK bullet. The canonical inclusions string is "<lead>: A · B · C · D".
   To keep copy fidelity (the decoded HTML must still contain the exact
   "·"-joined run), we model lead + items and re-emit the "·" separators as
   sr-only joiners between the visible lines — the visible list is per-line +
   checks, the accessible/decoded text stays the verbatim middot run. */
interface PackageTier {
  icon: IconName;
  iconColor?: string;
  price: string; // "Starting at $5K"
  name: string; // "Meeting Essentials"
  tagline: string;
  lead: string; // the prefix before the first "·", incl. its trailing ":"
  items: string[]; // the "·"-separated inclusions
  ignition?: boolean;
}
const packages: PackageTier[] = [
  {
    icon: "pkg-essentials",
    price: "Starting at <$5K",
    name: "Meeting Essentials",
    tagline: "Solid Essentials for Clear Communication",
    lead: "For Small-to-Medium Meetings:",
    items: ["No Frills", "No Compromises", "100% Reliable", "100% Pro"],
  },
  {
    icon: "pkg-conference",
    price: "Starting at <$20K",
    name: "Conference Package",
    tagline: "Clean, Transparent Production",
    lead: "The Meat and Potatoes:",
    items: [
      "Standard Ballroom Setup (Audio, Video and basic Front Lighting)",
      "Streaming Capabilities Included",
      "All the Essentials",
      "Insane Value through Efficiencies!",
    ],
  },
  {
    icon: "pkg-ignition",
    iconColor: "var(--color-accent-bright)",
    price: "Starting at <$50K",
    name: "Ignition Package",
    tagline: "Where Boring Goes to Die",
    lead: "This is gonna be fun!:",
    items: [
      "Unforgettable Impact",
      "All the Sizzle of the Vegas Strip",
      "Transformational vs. Informational",
      "Full Engagement",
    ],
    ignition: true,
  },
];

interface CapabilityColumn {
  icon: IconName;
  title: string;
  items: (string | { label: string; sub: string[] })[];
}
const capabilities: CapabilityColumn[] = [
  {
    icon: "cap-audio",
    title: "Audio",
    items: [
      { label: "Audio Consoles", sub: ["FOH", "Broadcast", "Monitor"] },
      "Wired / Wireless Microphones",
      "Wired / Wireless IEM / IFB systems",
      "Loudspeaker Arrays",
      "Delay Speakers",
      "Wedges",
      "Distributed Audio",
    ],
  },
  {
    icon: "cap-video",
    title: "Video / Streaming",
    items: [
      "IMAG",
      "Projection",
      "LED video walls",
      { label: "Cameras", sub: ["Studio-style", "PTZ", "Jib", "Roaming"] },
      "Downstage Monitors",
      "Remote Presenters",
      "Program + ISO recording (as needed)",
      { label: "Streaming / Meeting Platforms", sub: ["Zoom", "Teams", "Brushfire", "YouTube", "Resi"] },
    ],
  },
  {
    icon: "cap-graphics",
    title: "Presentation / GFX",
    items: [
      "PowerPoint",
      "Keynote",
      "ProPresenter",
      "Alpha Key",
      "Speaker Timers",
      "Bitfocus Companion / Streamdeck",
      'Perfect Cue "clickers"',
    ],
  },
  {
    icon: "cap-lighting",
    title: "Lighting / Scenic",
    items: [
      "Stage Wash Lights (Leko Style)",
      "Moving Lights (Profile + Wash)",
      "LED uplighting",
      "Wireless RGBW Table Lights",
      "Ground Support Systems",
      "Truss / Rigging",
      "Pipe and Drape (Velour)",
    ],

<BaseLayout
  title="AV Ninjas — Nashville Corporate AV & Event Production"
  description="Independent corporate AV and event production in Nashville — fully-crewed sound, video, and lighting with transparent pricing and no surprise charges. Meetings, conferences, and events done right, by a crew that handles it so you don't have to."
>
  <a href="#main" class="skip-link">Skip to content</a>
  <!-- §16 / B2 / B7: no-JS fallback — pre-draw every highlight marker so they are
       visible without scripts (the JS path animates them on scroll-into-view). -->
  <noscript>
    <style>
      .highlight-static,
      .nfb-seg { background-size: 100% 88% !important; transition: none !important; }
      /* No-JS: the continuous highlights are plain text inside .highlight-sweep (JS
         would rebuild them into per-line markers). Pre-highlight the whole wrapper so
         they read as one continuous highlight without scripts. */
      .highlight-sweep {
        background-image: linear-gradient(var(--color-highlight), var(--color-highlight));
        background-repeat: no-repeat;
        background-size: 100% 88% !important;
        background-position: 0 60%;
        color: var(--color-ink);
        box-decoration-break: clone;
        -webkit-box-decoration-break: clone;
      }
      /* v05: no-JS — The Ninjas points are shown immediately (no fade). */
      .ninjas-points li { opacity: 1 !important; transform: none !important; transition: none !important; }
    </style>
  </noscript>
  <SiteHeader />

  <main id="main">
    <!-- ============================================================
         BAND 1 — OPEN. Hero, canvas, standalone. (sweep §B.1)
         ============================================================ -->

    <!-- ============ 1. HERO (canvas, full viewport on load) ============ -->
    <!-- §9: the hero fills the ENTIRE viewport on first paint, every device.
         100dvh so mobile browser chrome can't break it. Left text block + right
         dominant image (the hero is the one "special" archetype — left, not
         centered, per sweep §A.3 row 1). -->
    <section class="hero-section" id="hero" aria-label="Hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <h1 class="display">Hey! We're the AV Ninjas.</h1>
          <!-- B3 (round-5): accent the three service words. Hero is a LIGHT ground →
               --color-accent (#1D4ED8), the light-voice accent (Iris flag). -->
          <!-- The trailing comma/space stays INSIDE each accent span so the decoded
               copy keeps "sound, video, and lighting" contiguous (the fidelity
               check collapses whitespace but each tag boundary injects a space —
               keeping punctuation in-span avoids a stray space before the comma).
               Only the words are visibly colored; "color" on a comma is invisible. -->
          <p class="lead">We provide <span class="svc-accent">sound, </span><span class="svc-accent">video, </span>and <span class="svc-accent">lighting</span> for meetings and events.</p>
          <p class="lead">
            We work directly with
            <!-- MOTION MOMENT 1 of 3: the one-and-only animated highlight (GL-003 §6).
                 Highlight Law v3 (Rev 9): CONTINUOUS highlight — ONE highlighter stroke.
                 Authored as plain text; JS rebuilds it into one .hl-line marker per
                 RENDERED line, and each line's bar wipes left→right as a single unit
                 (never per-word), handing off top→bottom. Correct at every wrap width.
                 Reduced-motion / no-JS: drawn end state. Verbatim copy unchanged —
                 exactly "EA's, Execs, Agencies and Event Planners". -->
            <span class="highlight-sweep" data-continuous-highlight>{heroHighlightWords.join(" ")}</span>
            - and our whole business is built around making it easy!
          </p>
          <p class="hero-kicker">Skip the headaches. Go Direct!</p>
          <div class="btn-row">
            <!-- Primary "Let's Talk" = the gradient POP moment (GL-003 §2 use #1).
                 Destination = Free Planning Call (Calendly). Ben ruling 2026-06-26:
                 the general site's universal "book a call" door is the planning call;
                 the Free AV Audit link is reserved EXCLUSIVELY for the dedicated audit
                 lander (the audit ads' destination) and must not be scattered on the
                 general site. -->
            <a href="https://calendly.com/ben-avninjas/free-planning-call" class="btn btn--gradient" target="_blank" rel="noopener noreferrer">Let's Talk!</a>
            <!-- Revision 6 (Ben): the hero "Learn More" loses its outline/border and
                 gains a small DOWN-ARROW to its right — it points to the content
                 below and reads as a "scroll down" affordance, not a bordered button.
                 (It still smooth-scrolls to #audiences — navigation, GL-003 §7.) -->
            <a href="#audiences" class="btn btn--learn">
              Learn More
              <svg class="btn-arrow" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true"
                   fill="none" stroke="currentColor" stroke-width="1.75"
                   stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 5v14"></path>
                <path d="M6 13l6 6 6-6"></path>
              </svg>
            </a>
          </div>
        </div>
        <Image
          class="img-real hero-img"
          src={heroTrioImg}
          alt={heroTrioAlt}
          widths={[480, 768, 1100, 1376]}
          sizes="(min-width: 920px) 56vw, 100vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </section>

    <!-- ============================================================
         BAND A — "Who you are / what you face." Audiences → Ticker →
         Attention → Sound Dramatic. Opens DARK (Audiences image-wall), then
         dark-fades up to canvas/cream. Earned dark moment: Audiences. (§B.1)

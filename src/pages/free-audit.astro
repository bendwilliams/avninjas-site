---
/**
 * /free-audit/ — the Free AV Audit landing page (Lane A). The ONLY on-site home of
 * the audit Calendly link (https://calendly.com/ben-avninjas/free-av-audit). Ben
 * ruling 2026-06-26: the audit offer lives here and NOWHERE else on the general
 * site — the general-site CTAs all go to the Free Planning Call. This page is the
 * destination the audit ADS point to.
 *
 * Voice: Lane A — solution-aware buyer (EAs / corporate event planners with prior
 * AV-vendor experience). The page is plainly the "Free AV Audit" (offer name matches
 * the Calendly event + dashboard). De-villained per Hook's tone revision AND Ben's
 * 2026-06-26 directive: NO "fishy" / villain framing anywhere on this page — title,
 * H1, meta, or body. "Fishy" is an AD hook only (the ad does the confrontation + the
 * click-through); the landing page is a low-threat "honest second opinion" on a past
 * AV invoice. H1 = the plain offer name; Hook's warm line "Want a second opinion…"
 * sits in the subhead. Offer assumes a past AV invoice worth reviewing (Lane A).
 *
 * Copy is VERBATIM from Hook's draft (tone-revised, through the read-aloud gate). The
 * geo line is load-bearing: the review is geo-bound by Ben's market knowledge (~200mi
 * of Nashville) per buyer-strategy §"Geo-Bound Offer Constraint".
 *
 * CTA mechanism mirrors the existing planning-call CTAs exactly:
 * <a class="btn btn--gradient" target="_blank" rel="noopener noreferrer"> (GL-003 §2
 * use #1 — the single promoted action; gradient pop is sanctioned for it).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const AUDIT_CALENDLY = "https://calendly.com/ben-avninjas/free-av-audit";

const auditTakeaways = [
  "A straight read on whether the number lines up with what the event calls for",
  "Where the budget actually goes, and what you're really paying for",
  "The handful of questions worth asking your venue before you sign",
  "If you've got an event coming up: our own quote for that same event, right next to theirs — so you've got a real number to compare, not a guess",
] as const;
---

<BaseLayout
  title="Free AV Audit | AV Ninjas"
  description="Send us the AV invoice from your last event, or a quote for an event coming up, and we'll take an honest look. Sometimes it's right in line; sometimes there's real money left on the table. Either way, you'll know. Free, no pitch. Nashville-area events."
>
  <a href="#main" class="skip-link">Skip to content</a>
  <SiteHeader />
  <main id="main">
    <!-- ============ HERO — plain offer name + second-opinion line (canvas, CENTERED) ============
         Ben directive 2026-06-26: the LANDING PAGE is plainly the "Free AV Audit". The
         confrontation hook is an AD-only device and must not appear here (title, H1,
         meta, or body). H1 = the plain offer name + the warm "second opinion" clause.
         The audit now accepts BOTH inputs (Hook revision): a PAST invoice OR an UPCOMING
         quote — for the quote case we put our own number beside theirs. Offer name kept
         "Free AV Audit" (matches the Calendly event + dashboard). -->
    <section class="section section--roomy center" aria-label="Free AV Audit">
      <div class="container">
        <div class="sec-head sec-head--wide">
          <p class="eyebrow">Free AV Audit · For event planners &amp; EAs in and around Nashville</p>
          <h1 class="display">Free AV Audit — a second opinion on what you're paying for AV</h1>
          <p class="lead">
            Send us the AV invoice from your last event, or a quote for an event coming up,
            and we'll take an honest look. Sometimes everything's right in line — and if it
            is, we'll tell you. Sometimes there's real money left on the table. Either way,
            you'll know. Free, and no pitch.
          </p>
        </div>
        <div class="btn-row center-row">
          <a href={AUDIT_CALENDLY} class="btn btn--gradient" target="_blank" rel="noopener noreferrer">
            Book your free AV audit →
          </a>
        </div>
        <p class="small muted audit-microcopy">
          30 minutes, by phone. Bring your last AV invoice — or a quote for an event coming up.
        </p>
      </div>
    </section>

    <!-- ============ CONTEXT + offer (cream band) ============ -->
    <section class="section section--cream" aria-label="What the review covers">
      <div class="container audit-narrow">
        <p>
          If you've planned a few events, you've signed a few AV invoices — and you've
          probably wondered once or twice whether the number was fair. Not because anyone
          did anything wrong. AV pricing just has a lot of moving parts, and it's hard to
          know what's normal when it's not the thing you do all day.
        </p>
        <p>
          It's the thing we do all day. So we're happy to be your gut-check — whether
          you're looking back at an event that's done, or sizing up a quote for one that's
          coming.
        </p>

        <p class="audit-offer-lead">
          On a 30-minute call, we'll walk through your invoice or quote together, and
          you'll come away with:
        </p>
        <ul class="audit-takeaways">
          {auditTakeaways.map((item) => <li>{item}</li>)}
        </ul>
        <p class="audit-keep"><em>You keep all of it whether or not we ever work together.</em></p>
      </div>
    </section>

    <!-- ============ WHY IT'S FREE + geo (canvas) ============ -->
    <section class="section" aria-label="Why it's free">
      <div class="container audit-narrow">
        <p>
          Why give this away? Honestly, because it's the best way we know to show you how
          we think. Sometimes the review turns up nothing and the number's perfectly fair —
          we'll happily say so. Sometimes it turns up real savings. We don't know which
          until we look, and we'll tell you the truth either way. And if you're shopping a
          quote right now, we'd genuinely love the chance to put ours beside it — no
          pressure, just an honest second number. If we're not the right fit, we'll say
          that too, and point you somewhere better.
        </p>
        <p>
          No obligation. No hard sell. Just a second set of eyes from someone who reads
          these all day.
        </p>
        <p class="audit-geo">
          One note: we review AV pricing for events in and around Nashville (roughly a
          200-mile radius), because that's the market we actually know. Planning a
          Nashville-area event from out of town? Still a yes — book the call.
        </p>
        <div class="btn-row center-row audit-final-cta">
          <a href={AUDIT_CALENDLY} class="btn btn--gradient" target="_blank" rel="noopener noreferrer">
            Book your free AV audit →
          </a>
        </div>
        <p class="small muted audit-microcopy">
          30 minutes, by phone. Bring your last AV invoice — or a quote for an event coming up.
        </p>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  /* .center / .center-row are scoped to index.astro (Astro component-scoped styles);
     redeclare the two we use here so the hero head + button rows center on this page. */
  .center { text-align: center; }
  .center .btn-row,
  .center-row { justify-content: center; }

  .audit-narrow {
    max-width: 720px;
  }
  .audit-narrow p {
    line-height: var(--leading-body);
    margin-bottom: var(--space-md);
  }
  .audit-microcopy {
    text-align: center;
    margin-top: var(--space-md);
    margin-bottom: 0;
  }
  .audit-offer-lead {
    font-weight: 600;
    margin-top: var(--space-xl);
  }
  .audit-takeaways {
    margin-bottom: var(--space-lg);
  }
  .audit-takeaways li {
    padding-block: var(--space-xs);
    line-height: var(--leading-body);
  }
  .audit-keep {
    margin-bottom: 0;
  }
  .audit-geo {
    margin-top: var(--space-lg);
  }
  .audit-final-cta {
    margin-top: var(--space-2xl);
  }
</style>

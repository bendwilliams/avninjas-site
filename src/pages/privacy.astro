---
/**
 * Privacy Policy (/privacy/) — required for LinkedIn Ads / LinkedIn Company Page
 * destinations. Standalone page with a back-to-home button; linked from the footer.
 *
 * NOTE FOR BEN: this is a sensible, plain-language starting policy that satisfies
 * the "must have a published privacy policy" requirement. Before relying on it
 * legally, confirm/replace the bracketed specifics (legal entity name, contact
 * email, analytics/ad tools actually in use, jurisdiction) and have counsel review.
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const lastUpdated = "June 25, 2026";
const effectiveDate = "June 25, 2026";
// Confirmed by Ben 2026-06-25: hello@ is the inbox for all website matters.
const contactEmail = "hello@avninjas.co";
---

<BaseLayout
  title="Privacy Policy — AV Ninjas"
  description="How AV Ninjas collects, uses, and protects information from visitors to this website."
>
  <main class="legal">
    <div class="legal__wrap">
      <a href={import.meta.env.BASE_URL} class="legal__back">← Back to home</a>

      <h1>Privacy Policy</h1>
      <p class="legal__updated">
        Effective: {effectiveDate} &middot; Last updated: {lastUpdated}
      </p>

      <p>
        This Privacy Policy explains how AV Ninjas ("we," "us," or "our") collects,
        uses, and protects information when you visit this website (avninjas.co),
        contact us, or request a quote. We keep things simple and collect only what
        we need to run the site, respond to you, and measure our advertising.
      </p>

      <h2>Information we collect</h2>
      <ul>
        <li>
          <strong>Information you give us.</strong> When you book a call, request a
          quote, or download a resource, we collect what you choose to send —
          typically your name, email address, company, and details about your event.
        </li>
        <li>
          <strong>Information collected automatically.</strong> Like most websites,
          we collect basic technical data such as your IP address, browser and
          device type, the page that referred you, and how you move through the
          site. This keeps the site working and helps us understand what's useful.
        </li>
        <li>
          <strong>Advertising &amp; campaign data.</strong> When you arrive from one
          of our ads, your link may carry campaign tags (for example
          <code>utm_source</code>, <code>utm_medium</code>, <code>utm_campaign</code>)
          and a platform click identifier (Google's <code>gclid</code>, Meta's
          <code>fbclid</code>, or LinkedIn's <code>li_fat_id</code>). We store these
          in a first-party cookie on your device and attach them to any form you
          submit, so we can tell which ad or campaign brought you here and measure
          what's working. This is essential to operating our advertising and runs
          regardless of your cookie choice; it does not by itself identify you.
        </li>
        <li>
          <strong>Cookies and similar technologies.</strong> We use a small number
          of <strong>essential</strong> cookies (and the first-party attribution
          cookie above) to make the site work, and — only with your consent —
          <strong>analytics</strong> and <strong>advertising</strong> cookies to
          understand usage and measure our ads. You control these through the cookie
          banner and can change your mind at any time (see "Your choices" below).
        </li>
      </ul>

      <h2>How we use information</h2>
      <ul>
        <li>To respond to your inquiries and provide quotes and services.</li>
        <li>To operate, maintain, secure, and improve this website.</li>
        <li>
          To measure the performance of our marketing and attribute leads to the
          ads and campaigns that generated them.
        </li>
        <li>To comply with legal obligations.</li>
      </ul>

      <h2>Cookies, analytics, and your consent</h2>
      <p>
        On your first visit we show a consent banner. Until you choose
        <strong>Accept</strong>, non-essential cookies stay off: we apply Google
        Consent Mode with analytics and advertising storage set to
        <strong>denied</strong> by default, so analytics and ad measurement do not
        run without your permission. Essential cookies (and the first-party
        attribution cookie) are always active because the site needs them to
        function.
      </p>
      <p>
        We manage our measurement tags through Google Tag Manager. With your
        consent, this may load analytics (Google Analytics) and advertising
        measurement tags. You can change or withdraw your consent at any time using
        the <a href="#" data-consent-open>cookie settings</a> link, or by clearing
        cookies in your browser.
      </p>

      <h2>How we share information &amp; third parties</h2>
      <p>
        We do not sell your personal information. We share data only with service
        providers who help us run the site, communicate with you, and measure our
        marketing, and when required by law. These providers process your
        information under their own privacy terms:
      </p>
      <ul>
        <li>
          <strong>Google</strong> — Tag Manager, Google Analytics, and Google Ads
          measurement (including the <code>gclid</code> click identifier). See
          Google's Privacy Policy.
        </li>
        <li>
          <strong>Meta (Facebook/Instagram)</strong> — ad measurement via the Meta
          pixel and the <code>fbclid</code> click identifier, if and when enabled.
          See Meta's Privacy Policy.
        </li>
        <li>
          <strong>LinkedIn</strong> — the LinkedIn Insight Tag and the
          <code>li_fat_id</code> click identifier for ad measurement. See LinkedIn's
          Privacy Policy.
        </li>
      </ul>
      <p>
        Analytics and advertising tags from Google, Meta, and LinkedIn load only
        after you consent. Some of these providers are based in, or transfer data
        to, the United States and other countries.
      </p>

      <h2>Your choices and rights</h2>
      <p>
        Depending on where you live, you may have the right to access, correct, or
        delete the personal information we hold about you, and to opt out of certain
        uses. To make a request, email us at <a href={`mailto:${contactEmail}`}
        >{contactEmail}</a>. You can also:
      </p>
      <ul>
        <li>
          Change your cookie consent any time via the
          <a href="#" data-consent-open>cookie settings</a> link.
        </li>
        <li>Manage or block cookies in your browser settings.</li>
        <li>
          Adjust ad preferences directly with Google, Meta, and LinkedIn, and opt
          out via the relevant industry opt-out tools.
        </li>
      </ul>

      <h2>Data retention &amp; security</h2>
      <p>
        We keep information only as long as we need it for the purposes above, then
        delete or anonymize it. The attribution cookie expires automatically after
        about 90 days, and your saved consent choice after about 180 days. We take
        reasonable measures to protect your information, though no method of
        transmission or storage is completely secure.
      </p>

      <h2>Children's privacy</h2>
      <p>
        This site is intended for businesses and is not directed to children under 16.
        We do not knowingly collect information from children.
      </p>

      <h2>Changes to this policy</h2>
      <p>
        We may update this policy from time to time. When we do, we'll revise the
        "Effective" and "Last updated" dates above.
      </p>

      <h2>Contact us</h2>
      <p>
        Questions about this policy? Email <a href={`mailto:${contactEmail}`}
        >{contactEmail}</a>.
      </p>

      <a href={import.meta.env.BASE_URL} class="legal__back legal__back--bottom">← Back to home</a>
    </div>
  </main>
</BaseLayout>

<style>
  .legal {
    background: var(--color-canvas);
    color: var(--color-ink);
    padding-block: var(--space-4xl);
  }
  .legal__wrap {
    max-width: 720px;
    margin-inline: auto;
    padding-inline: var(--space-xl);
  }
  .legal__back {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: var(--space-2xl);
  }
  .legal__back:hover { text-decoration: underline; }
  .legal__back--bottom { margin-top: var(--space-3xl); margin-bottom: 0; }
  .legal h1 { margin-bottom: var(--space-xs); }
  .legal__updated {
    color: var(--color-gray);
    font-size: var(--text-small);
    margin-top: 0;
    margin-bottom: var(--space-2xl);
  }
  .legal h2 {
    font-size: var(--text-h4);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-sm);
  }
  .legal p { margin-block: var(--space-md); line-height: var(--leading-body); }
  .legal ul { margin-block: var(--space-md); padding-left: var(--space-xl); }
  .legal li { padding-block: var(--space-2xs, 4px); line-height: var(--leading-body); }
  .legal a { color: var(--color-accent); }
  .legal code {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.9em;
    background: var(--color-cream);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
  }
</style>
